generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum AccountCategory {
  short_term_asset
  long_term_asset
  short_term_liability
  long_term_liability
  equity
  revenue
  operating_expense
  other_expense
  other_income
  cost_of_goods_sold
  manufacturing_cost
}

enum AccountNature {
  debit
  credit
}

enum JournalEntryStatus {
  draft
  submitted
  approved
  posted
  reversed
  cancelled
}

enum JournalType {
  standard
  recurring
  reversing
  accrual
  allocation
  adjustment
  closing
  opening
}

enum PeriodStatus {
  open
  closed
  locked
}

enum VoucherTypeCategory {
  payment
  receipt
  journal
  sales
  purchase
  payroll
  inventory
  fixed_asset
  tax
  other
}

enum SequenceMethod {
  annual
  monthly
  continuous
}

enum BudgetStatus {
  draft
  submitted
  approved
  rejected
  closed
}

enum BudgetType {
  operational
  capital
  project
  department
}

enum DimensionStatus {
  active
  inactive
}

enum ExchangeRateType {
  buy
  sell
  transfer
  reference
}

model Account {
  id               String          @id @default(uuid())
  code             String          @unique @db.VarChar(20)
  name             String          @db.VarChar(255)
  nameEn           String?         @db.VarChar(255)
  category         AccountCategory
  nature           AccountNature
  parentId         String?
  parent           Account?        @relation("AccountHierarchy", fields: [parentId], references: [id])
  children         Account[]       @relation("AccountHierarchy")
  isActive         Boolean         @default(true)
  isControl        Boolean         @default(false)
  isPosting        Boolean         @default(true)
  allowManualEntry Boolean         @default(true)
  balance          BigInt          @default(0)
  foreignBalance   BigInt          @default(0)
  currencyCode     String?         @db.VarChar(3)
  description      String?         @db.Text
  version          Int             @default(1)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  deletedAt        DateTime?

  journalLines  JournalEntryLine[]
  budgetLines   BudgetLine[]
  extensions    AccountExtension[]
  mappings      AccountMapping[]
  hierarchyChanges AccountHierarchyChange[]
  codeChanges   AccountCodeChange[]
  statusChanges AccountStatusChange[]

  @@index([code])
  @@index([parentId])
  @@index([category])
  @@index([isActive])
}

model FiscalYear {
  id        String   @id @default(uuid())
  code      String   @unique @db.VarChar(20)
  name      String   @db.VarChar(255)
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)
  isClosed  Boolean  @default(false)
  closedAt  DateTime?
  closedById String?
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  periods      Period[]
  budgets      Budget[]
  voucherSeries VoucherSeries[]
  journalBatches JournalBatch[]

  @@index([code])
  @@index([isActive])
}

model Period {
  id           String       @id @default(uuid())
  fiscalYearId String
  fiscalYear   FiscalYear   @relation(fields: [fiscalYearId], references: [id])
  periodNumber Int
  name         String       @db.VarChar(100)
  startDate    DateTime
  endDate      DateTime
  status       PeriodStatus @default(open)
  openedAt     DateTime     @default(now())
  closedAt     DateTime?
  closedById   String?
  version      Int          @default(1)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  journalBatches JournalBatch[]

  @@unique([fiscalYearId, periodNumber])
  @@index([fiscalYearId])
  @@index([status])
  @@index([startDate, endDate])
}

model VoucherType {
  id                String              @id @default(uuid())
  code              String              @unique @db.VarChar(20)
  name              String              @db.VarChar(255)
  category          VoucherTypeCategory
  description       String?             @db.Text
  requiresApproval  Boolean             @default(true)
  requiresAttachment Boolean            @default(false)
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  version           Int                 @default(1)

  voucherSeries VoucherSeries[]
  journalBatches JournalBatch[]

  @@index([code])
}

model VoucherSeries {
  id              String         @id @default(uuid())
  voucherTypeId   String
  voucherType     VoucherType    @relation(fields: [voucherTypeId], references: [id])
  code            String         @unique @db.VarChar(20)
  name            String         @db.VarChar(255)
  prefix          String         @db.VarChar(10)
  suffix          String?        @db.VarChar(10)
  currentNumber   Int            @default(0)
  nextNumber      Int            @default(1)
  minDigits       Int            @default(4)
  sequenceMethod  SequenceMethod @default(annual)
  fiscalYearId    String?
  fiscalYear      FiscalYear?    @relation(fields: [fiscalYearId], references: [id])
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  version         Int            @default(1)

  journalBatches JournalBatch[]

  @@index([voucherTypeId])
  @@index([code])
}

model JournalBatch {
  id               String             @id @default(uuid())
  batchNumber      String             @unique @db.VarChar(50)
  journalType      JournalType        @default(standard)
  status           JournalEntryStatus @default(draft)
  periodId         String
  period           Period             @relation(fields: [periodId], references: [id])
  fiscalYearId     String
  fiscalYear       FiscalYear         @relation(fields: [fiscalYearId], references: [id])
  voucherTypeId    String?
  voucherType      VoucherType?       @relation(fields: [voucherTypeId], references: [id])
  voucherSeriesId  String?
  voucherSeries    VoucherSeries?     @relation(fields: [voucherSeriesId], references: [id])
  voucherNumber    String?            @db.VarChar(50)
  voucherDate      DateTime
  postingDate      DateTime
  description      String             @db.Text
  reference        String?            @db.VarChar(100)
  source           String?            @db.VarChar(50)
  totalDebit       BigInt             @default(0)
  totalCredit      BigInt             @default(0)
  foreignTotalDebit  BigInt           @default(0)
  foreignTotalCredit BigInt           @default(0)
  currencyCode     String             @default("VND") @db.VarChar(3)
  exchangeRate     Decimal            @default(1.0) @db.Decimal(19, 6)
  isForeignCurrency Boolean           @default(false)
  approvedById     String?
  approvedAt       DateTime?
  postedById       String?
  postedAt         DateTime?
  reversedBatchId  String?
  recurringTemplateId String?
  attachmentCount  Int                @default(0)
  commentCount     Int                @default(0)
  createdById      String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  version          Int                @default(1)
  deletedAt        DateTime?

  lines JournalEntryLine[]

  @@index([batchNumber])
  @@index([periodId])
  @@index([fiscalYearId])
  @@index([status])
  @@index([postingDate])
  @@index([voucherDate])
  @@index([createdById])
  @@index([voucherTypeId])
}

model JournalEntryLine {
  id            String  @id @default(uuid())
  batchId       String
  batch         JournalBatch @relation(fields: [batchId], references: [id])
  accountId     String
  account       Account @relation(fields: [accountId], references: [id])
  debitAmount   BigInt  @default(0)
  creditAmount  BigInt  @default(0)
  foreignDebitAmount  BigInt  @default(0)
  foreignCreditAmount BigInt  @default(0)
  currencyCode  String  @default("VND") @db.VarChar(3)
  exchangeRate  Decimal @default(1.0) @db.Decimal(19, 6)
  description   String? @db.Text
  costCenterId  String?
  departmentId  String?
  projectId     String?
  lineOrder     Int

  @@index([batchId])
  @@index([accountId])
  @@index([costCenterId])
  @@index([departmentId])
}

model ExchangeRate {
  id           String           @id @default(uuid())
  fromCurrency String           @db.VarChar(3)
  toCurrency   String           @db.VarChar(3)
  rate         Decimal          @db.Decimal(19, 6)
  rateType     ExchangeRateType @default(reference)
  validFrom    DateTime
  validTo      DateTime
  source       String?          @db.VarChar(100)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  version      Int              @default(1)

  @@index([fromCurrency, toCurrency])
  @@index([validFrom, validTo])
}

model CostCenter {
  id            String          @id @default(uuid())
  code          String          @unique @db.VarChar(20)
  name          String          @db.VarChar(255)
  parentId      String?
  managerId     String?
  budgetHolderId String?
  status        DimensionStatus @default(active)
  description   String?         @db.Text
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  version       Int             @default(1)
  deletedAt     DateTime?

  @@index([code])
  @@index([status])
}

model Department {
  id          String          @id @default(uuid())
  code        String          @unique @db.VarChar(20)
  name        String          @db.VarChar(255)
  parentId    String?
  headId      String?
  status      DimensionStatus @default(active)
  description String?         @db.Text
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  version     Int             @default(1)
  deletedAt   DateTime?

  @@index([code])
  @@index([status])
}

model Budget {
  id                  String       @id @default(uuid())
  code                String       @unique @db.VarChar(20)
  name                String       @db.VarChar(255)
  type                BudgetType   @default(operational)
  status              BudgetStatus @default(draft)
  fiscalYearId        String
  fiscalYear          FiscalYear   @relation(fields: [fiscalYearId], references: [id])
  costCenterId        String?
  departmentId        String?
  projectId           String?
  totalOriginalAmount BigInt       @default(0)
  totalCurrentAmount  BigInt       @default(0)
  totalUsedAmount     BigInt       @default(0)
  totalRemainingAmount BigInt      @default(0)
  currencyCode        String       @default("VND") @db.VarChar(3)
  description         String?      @db.Text
  approvedById        String?
  approvedAt          DateTime?
  createdById         String
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  version             Int          @default(1)
  deletedAt           DateTime?

  lines BudgetLine[]

  @@index([fiscalYearId])
  @@index([costCenterId])
  @@index([status])
}

model BudgetLine {
  id              String @id @default(uuid())
  budgetId        String
  budget          Budget @relation(fields: [budgetId], references: [id])
  accountId       String
  account         Account @relation(fields: [accountId], references: [id])
  originalAmount  BigInt @default(0)
  currentAmount   BigInt @default(0)
  usedAmount      BigInt @default(0)
  remainingAmount BigInt @default(0)
  period1         BigInt @default(0)
  period2         BigInt @default(0)
  period3         BigInt @default(0)
  period4         BigInt @default(0)
  period5         BigInt @default(0)
  period6         BigInt @default(0)
  period7         BigInt @default(0)
  period8         BigInt @default(0)
  period9         BigInt @default(0)
  period10        BigInt @default(0)
  period11        BigInt @default(0)
  period12        BigInt @default(0)

  @@index([budgetId])
  @@index([accountId])
}

model AuditLog {
  id            String   @id @default(uuid())
  entityType    String   @db.VarChar(50)
  entityId      String   @db.VarChar(36)
  action        String   @db.VarChar(50)
  changes       Json?
  performedById String
  performedAt   DateTime @default(now())
  ipAddress     String?  @db.VarChar(45)
  userAgent     String?  @db.VarChar(255)
  batchId       String?

  @@index([entityType, entityId])
  @@index([performedById])
  @@index([performedAt])
  @@index([batchId])
}

enum TaxCategory {
  value_added_tax
  corporate_income_tax
  personal_income_tax
  special_consumption_tax
  natural_resource_tax
  environmental_tax
  customs_duty
  land_tax
  license_tax
  other
}

enum TaxRateType {
  percentage
  fixed_amount
  mixed
}

enum TaxApplication {
  sales
  purchases
  imports
  exports
  both
}

enum TaxBasis {
  revenue
  profit
  salary
  consumption
  resource_volume
  land_area
  customs_value
  other
}

enum TaxCalculationMethod {
  direct
  deduction
  withholding
  presumptive
  hybrid
}

enum TaxPaymentMethod {
  monthly
  quarterly
  annual
  per_transaction
  withholding
}

enum TaxFilingFrequency {
  monthly
  quarterly
  annual
  per_transaction
}

enum TaxRegistrationStatus {
  draft
  submitted
  active
  suspended
  cancelled
  closed
}

enum TaxReturnStatus {
  draft
  prepared
  submitted
  accepted
  rejected
  amended
  closed
}

enum TaxReturnType {
  original
  amended
  supplementary
  final
}

enum TaxExemptionType {
  full_exemption
  partial_exemption
  reduced_rate
  tax_holiday
  investment_incentive
  export_incentive
  special_economic_zone
}

enum TaxExemptionStatus {
  active
  used
  expired
  revoked
}

enum TaxPaymentStatus {
  pending
  due
  paid
  overdue
  partially_paid
  refunded
  cancelled
  fully_refunded
  failed
}

model TaxType {
  id                  String          @id @default(uuid())
  code                String          @unique @db.VarChar(20)
  name                String          @db.VarChar(255)
  nameEn              String?         @db.VarChar(255)
  category            TaxCategory
  nature              String          @db.VarChar(20)
  basis               TaxBasis
  calculationMethod   TaxCalculationMethod @map("calculation_method")
  paymentMethod       TaxPaymentMethod     @map("payment_method")
  filingFrequency     TaxFilingFrequency   @map("filing_frequency")
  description         String?         @db.Text
  legalReference      String?         @db.VarChar(255)
  isActive            Boolean         @default(true) @map("is_active")
  requiresRegistration Boolean        @default(true)
  requiresDeclaration  Boolean        @default(true)
  requiresPayment     Boolean         @default(true)
  hasWithholding      Boolean         @default(false)
  hasExemption        Boolean         @default(false)
  hasIncentive        Boolean         @default(false)
  priority            Int             @default(0)
  parentTaxTypeId     String?         @map("parent_tax_type_id")
  version             Int             @default(1)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  codes               TaxCode[]
  registrations       TaxRegistration[]
  returns             TaxReturn[]
  exemptions          TaxExemption[]
  payments            TaxPayment[]
  determinationRules  TaxDeterminationRule[]

  @@index([category])
  @@index([isActive])
  @@map("tax_types")
}

model TaxCode {
  id                  String          @id @default(uuid())
  code                String          @unique @db.VarChar(20)
  name                String          @db.VarChar(255)
  taxTypeId           String
  taxType             TaxType         @relation(fields: [taxTypeId], references: [id])
  taxRateType         TaxRateType     @map("tax_rate_type")
  application         TaxApplication
  roundingMethod      String          @default("round")
  precision           Int             @default(0)
  description         String?         @db.Text
  isActive            Boolean         @default(true)
  isRecoverable       Boolean         @default(true)
  isRefundable        Boolean         @default(false)
  isDeductible        Boolean         @default(true)
  glTaxAccountId      String?         @map("gl_tax_account_id")
  glRecoverableAccountId String?      @map("gl_recoverable_account_id")
  glExpenseAccountId  String?         @map("gl_expense_account_id")
  effectiveFrom       DateTime
  effectiveTo         DateTime?
  version             Int             @default(1)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  rates               TaxRate[]
  exemptions          TaxExemption[]

  @@index([taxTypeId])
  @@map("tax_codes")
}

model TaxRate {
  id                  String          @id @default(uuid())
  taxCodeId           String
  taxCode             TaxCode         @relation(fields: [taxCodeId], references: [id])
  rate                Decimal         @db.Decimal(19, 6)
  rateType            TaxRateType     @default(percentage)
  minimumAmount       BigInt?
  maximumAmount       BigInt?
  effectiveFrom       DateTime
  effectiveTo         DateTime?
  priority            Int             @default(0)
  isActive            Boolean         @default(true)
  version             Int             @default(1)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([taxCodeId])
  @@index([taxCodeId, effectiveFrom, effectiveTo])
  @@map("tax_rates")
}

model TaxAuthority {
  id                  String          @id @default(uuid())
  code                String          @unique @db.VarChar(20)
  name                String          @db.VarChar(255)
  taxOfficeCode       String          @db.VarChar(20)
  jurisdictionLevel   String          @db.VarChar(20)
  parentId            String?
  parent              TaxAuthority?   @relation("TaxAuthorityHierarchy", fields: [parentId], references: [id])
  children            TaxAuthority[]  @relation("TaxAuthorityHierarchy")
  address             String?         @db.Text
  phone               String?         @db.VarChar(20)
  email               String?         @db.VarChar(255)
  website             String?         @db.VarChar(255)
  isActive            Boolean         @default(true)
  version             Int             @default(1)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([jurisdictionLevel])
  @@map("tax_authorities")
}

model TaxRegion {
  id                  String          @id @default(uuid())
  code                String          @unique @db.VarChar(20)
  name                String          @db.VarChar(255)
  type                String          @db.VarChar(30)
  provinceCode        String?         @db.VarChar(10)
  districtCode        String?         @db.VarChar(10)
  wardCode            String?         @db.VarChar(10)
  isActive            Boolean         @default(true)
  version             Int             @default(1)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([type])
  @@index([provinceCode])
  @@map("tax_regions")
}

model TaxRegistration {
  id                  String              @id @default(uuid())
  registrationNumber  String              @unique @db.VarChar(50)
  taxpayerId          String              @db.VarChar(36)
  taxpayerName        String              @db.VarChar(255)
  taxTypeId           String
  taxType             TaxType             @relation(fields: [taxTypeId], references: [id])
  taxAuthorityId      String?
  status              TaxRegistrationStatus @default(draft)
  registrationDate    DateTime?
  deregistrationDate  DateTime?
  suspensionDate      DateTime?
  reason              String?             @db.Text
  submittedById       String?
  approvedById        String?
  approvedAt          DateTime?
  description         String?             @db.Text
  version             Int                 @default(1)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([taxpayerId])
  @@index([taxTypeId])
  @@index([status])
  @@map("tax_registrations")
}

model TaxExemption {
  id                  String              @id @default(uuid())
  code                String              @unique @db.VarChar(50)
  name                String              @db.VarChar(255)
  exemptionType       TaxExemptionType
  status              TaxExemptionStatus  @default(active)
  taxTypeId           String
  taxType             TaxType             @relation(fields: [taxTypeId], references: [id])
  taxCodeId           String?
  taxCode             TaxCode?            @relation(fields: [taxCodeId], references: [id])
  taxpayerId          String?             @db.VarChar(36)
  exemptPercentage    Decimal?            @db.Decimal(5, 2)
  exemptAmount        BigInt?
  maxAmount           BigInt?
  validFrom           DateTime
  validTo             DateTime?
  issuingAuthority    String?             @db.VarChar(255)
  referenceNumber     String?             @db.VarChar(100)
  reason              String?             @db.Text
  description         String?             @db.Text
  version             Int                 @default(1)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([taxTypeId])
  @@index([taxpayerId])
  @@index([status])
  @@map("tax_exemptions")
}

model TaxReturn {
  id                  String              @id @default(uuid())
  returnNumber        String              @unique @db.VarChar(50)
  returnType          TaxReturnType       @default(original)
  status              TaxReturnStatus     @default(draft)
  taxTypeId           String
  taxType             TaxType             @relation(fields: [taxTypeId], references: [id])
  taxpayerId          String              @db.VarChar(36)
  taxpayerName        String              @db.VarChar(255)
  periodId            String              @db.VarChar(36)
  periodName          String              @db.VarChar(100)
  fiscalYearId        String
  totalTaxAmount      BigInt              @default(0)
  totalPaidAmount     BigInt              @default(0)
  totalDueAmount      BigInt              @default(0)
  totalCreditAmount   BigInt              @default(0)
  currencyCode        String              @default("VND") @db.VarChar(3)
  exchangeRate        Decimal             @default(1.0) @db.Decimal(19, 6)
  originalReturnId    String?
  submittedById       String?
  submittedAt         DateTime?
  approvedById        String?
  approvedAt          DateTime?
  description         String?             @db.Text
  version             Int                 @default(1)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  payments            TaxPayment[]

  @@index([taxpayerId])
  @@index([taxTypeId])
  @@index([status])
  @@index([periodId])
  @@map("tax_returns")
}

model TaxPayment {
  id                  String              @id @default(uuid())
  paymentNumber       String              @unique @db.VarChar(50)
  taxReturnId         String?
  taxReturn           TaxReturn?          @relation(fields: [taxReturnId], references: [id])
  taxTypeId           String
  taxType             TaxType             @relation(fields: [taxTypeId], references: [id])
  taxpayerId          String              @db.VarChar(36)
  amount              BigInt              @default(0)
  paidAmount          BigInt              @default(0)
  refundAmount        BigInt              @default(0)
  status              TaxPaymentStatus    @default(pending)
  paymentDate         DateTime?
  dueDate             DateTime?
  paymentMethod       String?             @db.VarChar(50)
  reference           String?             @db.VarChar(100)
  bankAccount         String?             @db.VarChar(50)
  glBatchId           String?
  description         String?             @db.Text
  version             Int                 @default(1)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([taxReturnId])
  @@index([taxpayerId])
  @@index([status])
  @@map("tax_payments")
}

model TaxDeterminationRule {
  id                  String          @id @default(uuid())
  taxTypeId           String
  taxType             TaxType         @relation(fields: [taxTypeId], references: [id])
  ruleOrder           Int
  conditionField      String          @db.VarChar(50)
  conditionOperator   String          @db.VarChar(20)
  conditionValue      String          @db.VarChar(255)
  resultTaxCodeId     String?         @db.VarChar(36)
  resultRate          Decimal?        @db.Decimal(19, 6)
  effectiveFrom       DateTime
  effectiveTo         DateTime?
  description         String?         @db.Text
  isActive            Boolean         @default(true)
  version             Int             @default(1)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([taxTypeId])
  @@index([effectiveFrom, effectiveTo])
  @@map("tax_determination_rules")
}

