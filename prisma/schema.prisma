  deletedAt     DateTime?

  @@index([employeeId])
  @@index([startDate, endDate])
  @@map("prl_leave_records")
}

// ─── Payroll Transaction ─────────────────────────────────────────────────────

model PrlPayrollRun {
  id              String              @id @default(uuid())
  runNumber       String              @unique @db.VarChar(50)
  groupId         String              @db.VarChar(36)
  group           PrlPayrollGroup     @relation(fields: [groupId], references: [id])
  periodId        String              @db.VarChar(36)
  period          PrlPayrollPeriod    @relation(fields: [periodId], references: [id])
  calendarId      String              @db.VarChar(36)
  name            String              @db.VarChar(255)
  status          PrlPayrollRunStatus @default(draft)
  companyId       String              @db.VarChar(36)
  branchId        String?             @db.VarChar(36)
  currencyCode    String              @default("VND") @db.VarChar(3)
  exchangeRate    Decimal             @default(1) @db.Decimal(18, 6)
  // Totals
  totalEarnings   BigInt              @default(0)
  totalDeductions BigInt              @default(0)
  totalEmployerCost BigInt            @default(0)
  totalNetPay     BigInt              @default(0)
  totalPIT        BigInt              @default(0)
  totalInsurance  BigInt              @default(0)
  employeeCount   Int                 @default(0)
  // Dates
  calculationDate DateTime?
  approvedDate    DateTime?
  approvedById    String?             @db.VarChar(100)
  postedDate      DateTime?
  postedById      String?             @db.VarChar(100)
  paidDate        DateTime?
  paidById        String?             @db.VarChar(100)
  reversedDate    DateTime?
  reversedById    String?             @db.VarChar(100)
  reverseOfId     String?             @db.VarChar(36)
  // GL
  glBatchId       String?             @db.VarChar(36)
  postedToGL      Boolean             @default(false)
  // Notes
  notes           String?             @db.Text
  // Audit
  version         Int                 @default(1)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?

  payrollLines       PrlPayrollLine[]
  payrollPayments    PrlPayrollPayment[]
  payrollJournals    PrlPayrollJournal[]
  approvals          PrlPayrollApproval[]

  @@index([runNumber])
  @@index([groupId])
  @@index([periodId])
  @@index([status])
  @@index([companyId])
  @@map("prl_payroll_runs")
}

model PrlPayrollLine {
  id          String         @id @default(uuid())
  runId       String         @db.VarChar(36)
  payrollRun  PrlPayrollRun  @relation(fields: [runId], references: [id])
  employeeId  String         @db.VarChar(36)
  employee    PrlEmployeePayroll @relation(fields: [employeeId], references: [id])
  lineNumber  Int
  // Employee info snapshot
  employeeCode  String       @db.VarChar(50)
  employeeName  String       @db.VarChar(255)
  departmentId  String?      @db.VarChar(36)
  costCenterId  String?      @db.VarChar(36)
  branchId      String?      @db.VarChar(36)
  taxCode       String?      @db.VarChar(20)
  socialInsuranceNo String?  @db.VarChar(20)
  bankAccountId String?      @db.VarChar(36)
  // Amounts
  totalEarnings   BigInt     @default(0)
  totalDeductions BigInt     @default(0)
  grossPay        BigInt     @default(0)
  totalInsurance  BigInt     @default(0)
  totalPIT        BigInt     @default(0)
  netPay          BigInt     @default(0)
  employerCost    BigInt     @default(0)
  // Working days
  workingDays     Decimal    @default(0) @db.Decimal(5, 2)
  overtimeHours   Decimal    @default(0) @db.Decimal(5, 2)
  leaveDays       Decimal    @default(0) @db.Decimal(5, 2)
  absenceDays     Decimal    @default(0) @db.Decimal(5, 2)
  // Status
  isCalculated    Boolean    @default(false)
  isExcluded      Boolean    @default(false)
  excludeReason   String?    @db.Text
  notes           String?    @db.Text
  // Audit
  version         Int        @default(1)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  elements PrlPayrollElement[]

  @@index([runId])
  @@index([employeeId])
  @@index([runId, employeeId])
  @@map("prl_payroll_lines")
}

model PrlPayrollElement {
  id            String             @id @default(uuid())
  lineId        String             @db.VarChar(36)
  line          PrlPayrollLine     @relation(fields: [lineId], references: [id])
  componentId   String             @db.VarChar(36)
  component     PrlSalaryComponent @relation(fields: [componentId], references: [id])
  elementName   String             @db.VarChar(255)
  elementType   PrlElementType
  category      PrlElementCategory
  amount        BigInt             @default(0)
  baseAmount    BigInt             @default(0)
  quantity      Decimal?           @db.Decimal(12, 2)
  rate          Decimal?           @db.Decimal(12, 2)
  isTaxable     Boolean            @default(true)
  isInsurable   Boolean            @default(false)
  isPITable      Boolean           @default(true)
  notes         String?            @db.Text
  version       Int                @default(1)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?

  @@index([lineId])
  @@index([componentId])
  @@map("prl_payroll_elements")
}

// ─── Payroll Approval ────────────────────────────────────────────────────────

