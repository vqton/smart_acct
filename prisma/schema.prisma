}

model BnkPaymentBatch {
  id              String                @id @default(uuid())
  companyId       String
  batchNumber     String                @unique @db.VarChar(50)
  status          BnkPaymentBatchStatus @default(draft)
  paymentCount    Int                   @default(0)
  totalAmount     BigInt                @default(0)
  currencyCode    String                @default("VND") @db.VarChar(3)
  paymentDate     DateTime
  valueDate       DateTime?
  approvedById    String?               @db.VarChar(36)
  approvedAt      DateTime?
  releasedById    String?               @db.VarChar(36)
  releasedAt      DateTime?
  completedAt     DateTime?
  failureCount    Int                   @default(0)
  version         Int                   @default(1)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  deletedAt       DateTime?

  @@index([companyId])
  @@index([batchNumber])
  @@index([status])
  @@map("bnk_payment_batches")
}

model BnkRecurringPayment {
  id                  String               @id @default(uuid())
  companyId           String
  name                String               @db.VarChar(255)
  fromAccountId       String
  toAccountId         String?              @db.VarChar(36)
  beneficiaryName     String               @db.VarChar(255)
  beneficiaryAccount  String?              @db.VarChar(50)
  beneficiaryBank     String?              @db.VarChar(255)
  amount              BigInt               @default(0)
  currencyCode        String               @default("VND") @db.VarChar(3)
  frequency           BnkRecurringFrequency
  interval            Int                  @default(1)
  startDate           DateTime
  endDate             DateTime?
  nextExecutionDate   DateTime
  lastExecutionDate   DateTime?
  executionCount      Int                  @default(0)
  maxExecutions       Int?
  method              BnkTransactionMethod @default(wire)
  reference           String?              @db.VarChar(100)
  description         String?              @db.Text
  isActive            Boolean              @default(true)
  version             Int                  @default(1)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?

  @@index([companyId])
  @@index([fromAccountId])
  @@index([nextExecutionDate])
  @@map("bnk_recurring_payments")
}

// ─── Treasury & Cash Positioning ────────────────────────────────────────────────

model BnkCashPosition {
  id               String               @id @default(uuid())
  companyId        String
  positionDate     DateTime
  currencyCode     String               @default("VND") @db.VarChar(3)
  openingBalance   BigInt               @default(0)
  totalInflows     BigInt               @default(0)
  totalOutflows    BigInt               @default(0)
  netFlow          BigInt               @default(0)
  closingBalance   BigInt               @default(0)
  availableBalance  BigInt              @default(0)
  blockedBalance   BigInt               @default(0)
  pendingInflows   BigInt               @default(0)
  pendingOutflows  BigInt               @default(0)
  projectedBalance BigInt               @default(0)
  minimumBalance   BigInt               @default(0)
  maximumBalance   BigInt               @default(0)
  status           BnkCashPositionStatus @default(draft)
  isReconciled     Boolean              @default(false)
  version          Int                  @default(1)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  deletedAt        DateTime?

  @@unique([companyId, positionDate, currencyCode])
  @@index([companyId])
  @@index([positionDate])
  @@map("bnk_cash_positions")
}

model BnkCashForecast {
  id                String               @id @default(uuid())
  companyId         String
  forecastNumber    String               @unique @db.VarChar(50)
  name              String               @db.VarChar(255)
  periodStart       DateTime
  periodEnd         DateTime
  currencyCode      String               @default("VND") @db.VarChar(3)
  openingBalance    BigInt               @default(0)
  projectedInflows  BigInt               @default(0)
  projectedOutflows BigInt               @default(0)
  netProjected      BigInt               @default(0)
  closingBalance    BigInt               @default(0)
  minimumRequired   BigInt               @default(0)
  surplusDeficit    BigInt               @default(0)
  confidenceLevel   Decimal              @default(0) @db.Decimal(5, 2)
  status            BnkCashPositionStatus @default(draft)
  version           Int                  @default(1)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  deletedAt         DateTime?

  @@index([companyId])
  @@index([periodStart, periodEnd])
  @@map("bnk_cash_forecasts")
}

// ─── Foreign Exchange ───────────────────────────────────────────────────────────

model BnkFXRate {
  id            String        @id @default(uuid())
  fromCurrency  String        @db.VarChar(3)
  toCurrency    String        @db.VarChar(3)
  rate          Decimal       @db.Decimal(19, 6)
  rateType      BnkFXRateType @default(reference)
  validFrom     DateTime
  validTo       DateTime
  source        String?       @db.VarChar(100)
  isActive      Boolean       @default(true)
  version       Int           @default(1)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([fromCurrency, toCurrency])
  @@index([validFrom, validTo])
  @@map("bnk_fx_rates")
}

model BnkFXRevaluation {
  id                  String   @id @default(uuid())
  companyId           String
  revaluationDate     DateTime
  currencyCode        String   @db.VarChar(3)
  exchangeRate        Decimal  @db.Decimal(19, 6)
  previousRate        Decimal  @db.Decimal(19, 6)
  accountId           String   @db.VarChar(36)
  accountBalance      BigInt   @default(0)
  fxGainLoss          BigInt   @default(0)
  gainLossType        String   @db.VarChar(4)
  isRealized          Boolean  @default(false)
  sourceTransactionId String?  @db.VarChar(36)
  glBatchId           String?
  postedToGL          Boolean  @default(false)
  version             Int      @default(1)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([companyId])
  @@index([accountId])
  @@index([revaluationDate])
  @@map("bnk_fx_revaluations")
}

// ─── Approval Matrix ────────────────────────────────────────────────────────────

model BnkApprovalMatrix {
  id            String          @id @default(uuid())
  companyId     String
  name          String          @db.VarChar(255)
  entityType    String          @db.VarChar(50)
  minAmount     BigInt          @default(0)
  maxAmount     BigInt          @default(0)
  currencyCode  String          @default("VND") @db.VarChar(3)
  approvalMode  BnkApprovalMode @default(sequential)
  levels        Int             @default(1)
  isActive      Boolean         @default(true)
  version       Int             @default(1)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  levelsDef BnkApprovalMatrixLevel[]

  @@index([companyId])
  @@index([entityType])
  @@map("bnk_approval_matrices")
}

model BnkApprovalMatrixLevel {
  id            String   @id @default(uuid())
  matrixId      String
  matrix        BnkApprovalMatrix @relation(fields: [matrixId], references: [id])
  level         Int
  approverId    String   @db.VarChar(36)
  approverName  String?  @db.VarChar(255)
  minAmount     BigInt   @default(0)
  maxAmount     BigInt   @default(0)
  isRequired    Boolean  @default(true)

  @@index([matrixId])
  @@map("bnk_approval_matrix_levels")
}

model BnkApprovalRequest {
  id              String           @id @default(uuid())
  requestNumber   String           @unique @db.VarChar(50)
  entityType      String           @db.VarChar(50)
  entityId        String           @db.VarChar(36)
  amount          BigInt           @default(0)
  currencyCode    String           @default("VND") @db.VarChar(3)
  status          BnkApprovalStatus @default(pending)
  currentLevel    Int              @default(1)
  maxLevel        Int              @default(1)
  approvalMode    BnkApprovalMode  @default(sequential)
  requestedById   String           @db.VarChar(36)
  requestedAt     DateTime
  completedAt     DateTime?
  notes           String?          @db.Text
  version         Int              @default(1)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  steps BnkApprovalStep[]

  @@index([entityType, entityId])
  @@index([status])
  @@index([requestedById])
  @@map("bnk_approval_requests")
}

model BnkApprovalStep {
  id            String           @id @default(uuid())
  approvalId    String
  approval      BnkApprovalRequest @relation(fields: [approvalId], references: [id])
  level         Int
  approverId    String           @db.VarChar(36)
  approverName  String?          @db.VarChar(255)
  status        BnkApprovalStatus @default(pending)
  actionAt      DateTime?
  comment       String?          @db.Text
  escalatedAt   DateTime?
  delegatedTo   String?          @db.VarChar(36)

  @@index([approvalId])
  @@index([approverId])
  @@index([status])
  @@map("bnk_approval_steps")
}

// ─── Charges & Interest ─────────────────────────────────────────────────────────

model BnkCharge {
  id              String        @id @default(uuid())
