model FrReportCategory {
  id          String              @id @default(uuid())
  code        String              @unique @db.VarChar(20)
  name        String              @db.VarChar(255)
  nameEn      String?             @db.VarChar(255)
  categoryType FrReportCategoryType
  description String?             @db.Text
  displayOrder Int                @default(0)
  parentId    String?
  parent      FrReportCategory?    @relation("ReportCategoryHierarchy", fields: [parentId], references: [id])
  children    FrReportCategory[]   @relation("ReportCategoryHierarchy")
  isActive    Boolean             @default(true)
  version     Int                 @default(1)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  reports FrReportDefinition[]

  @@index([code])
  @@index([categoryType])
  @@map("fr_report_categories")
}

model FrReportDefinition {
  id            String             @id @default(uuid())
  code          String             @unique @db.VarChar(20)
  name          String             @db.VarChar(255)
  nameEn        String?            @db.VarChar(255)
  categoryId    String
  category      FrReportCategory   @relation(fields: [categoryId], references: [id])
  status        FrReportStatus     @default(draft)
  description   String?            @db.Text

  // Display
  displayCurrency String           @default("VND") @db.VarChar(3)
  displayScale    Int              @default(0)
  displayDecimals Int              @default(0)
  isComparative   Boolean          @default(false)
  comparativePeriods Int           @default(1)
  isConsolidated  Boolean          @default(false)

  // Period
  defaultFiscalYearId String?      @db.VarChar(36)
  defaultPeriodType  String        @default("monthly") @db.VarChar(20)

  // Ownership
  ownerId        String?           @db.VarChar(36)
  isPublic       Boolean           @default(false)

  // Audit
  version        Int               @default(1)
  createdById    String            @db.VarChar(36)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?

  rows           FrReportRow[]
  instances      FrReportInstance[]
  schedules      FrReportSchedule[]
  exports        FrReportExport[]
  approvals      FrReportApproval[]

  @@index([code])
  @@index([categoryId])
  @@index([status])
  @@map("fr_report_definitions")
}

model FrReportRow {
  id              String          @id @default(uuid())
  reportId        String
  report          FrReportDefinition @relation(fields: [reportId], references: [id])
  parentRowId     String?
  parentRow       FrReportRow?    @relation("ReportRowHierarchy", fields: [parentRowId], references: [id])
  children        FrReportRow[]   @relation("ReportRowHierarchy")
  rowType         FrRowType       @default(description)
  rowCode         String?         @db.VarChar(20)
  label           String          @db.VarChar(255)
  labelEn         String?         @db.VarChar(255)
  displayOrder    Int             @default(0)
  indentLevel     Int             @default(0)
  isBold          Boolean         @default(false)
  isItalic        Boolean         @default(false)
  isUnderline     Boolean         @default(false)
  isVisible       Boolean         @default(true)
  showSubtotal    Boolean         @default(false)
  pageBreakBefore Boolean         @default(false)
  description     String?         @db.Text
  version         Int             @default(1)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  cells FrReportCell[]

  @@index([reportId])
  @@index([parentRowId])
  @@map("fr_report_rows")
}

model FrReportCell {
  id              String          @id @default(uuid())
  rowId           String
  row             FrReportRow     @relation(fields: [rowId], references: [id])
  columnId        String?         @db.VarChar(36)
  cellType        FrCellType      @default(value)
  formulaId       String?         @db.VarChar(36)
  formulaText     String?         @db.Text
  accountCode     String?         @db.VarChar(20)
  accountId       String?         @db.VarChar(36)

  // Account filter
  accountCategory String?         @db.VarChar(30)
  accountNature   String?         @db.VarChar(10)
  includeControlAccounts Boolean   @default(false)
  includeSubAccounts    Boolean   @default(true)

  // Aggregation
  aggregationFunction String?     @db.VarChar(20)
  aggregationPeriod  String?      @db.VarChar(20)
  periodOffset      Int           @default(0)
  periodCount       Int           @default(1)

  // Dimension filter
  costCenterId    String?         @db.VarChar(36)
  departmentId    String?         @db.VarChar(36)
  projectId       String?         @db.VarChar(36)
  branchId        String?         @db.VarChar(36)
  legalEntityId   String?         @db.VarChar(36)

  // Formatting
  formatPattern   String?         @db.VarChar(50)
  decimalPlaces   Int             @default(0)
  scaleFactor     Decimal         @default(1) @db.Decimal(19, 6)
  prefix          String?         @db.VarChar(20)
  suffix          String?         @db.VarChar(20)
  cssClass        String?         @db.VarChar(50)

  // Conditional display
  hideIfZero      Boolean         @default(false)
  hideIfNegative  Boolean         @default(false)
  showIfFormula   String?         @db.Text

  // Static value
  staticValue     String?         @db.VarChar(255)

  version         Int             @default(1)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([rowId])
  @@index([formulaId])
  @@map("fr_report_cells")
}

model FrFormula {
  id              String          @id @default(uuid())
  code            String          @unique @db.VarChar(20)
  name            String          @db.VarChar(255)
  formulaType     FrFormulaType   @default(simple)
  expression      String          @db.Text
  description     String?         @db.Text

  // Validation
  returnType      String          @db.VarChar(20)
  minValue        Decimal?        @db.Decimal(25, 6)
  maxValue        Decimal?        @db.Decimal(25, 6)
  validationRule  String?         @db.Text

  // Versioning
  version         Int             @default(1)
  isActive        Boolean         @default(true)
  createdById     String          @db.VarChar(36)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  @@index([code])
  @@index([formulaType])
  @@map("fr_formulas")
}

model FrReportInstance {
  id              String             @id @default(uuid())
  reportId        String
  report          FrReportDefinition @relation(fields: [reportId], references: [id])
  instanceNumber  String             @unique @db.VarChar(50)
  status          FrInstanceStatus   @default(generating)

  // Period
  fiscalYearId    String             @db.VarChar(36)
  periodId        String?            @db.VarChar(36)
  periodNumber    Int?
  periodName      String?            @db.VarChar(100)
  asOfDate        DateTime?

  // Reporting entity
  legalEntityId   String?            @db.VarChar(36)
  consolidationRunId String?         @db.VarChar(36)

  // Currency
  reportingCurrency String           @default("VND") @db.VarChar(3)
  exchangeRate     Decimal           @default(1) @db.Decimal(19, 6)

  // Audit
  generatedById   String             @db.VarChar(36)
  generatedAt     DateTime           @default(now())
  approvedById    String?            @db.VarChar(36)
  approvedAt      DateTime?
  lockedById      String?            @db.VarChar(36)
  lockedAt        DateTime?
  errorMessage    String?            @db.Text
  version         Int                @default(1)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?

  rows            FrReportInstanceRow[]
  scheduleId      String?
  schedule        FrReportSchedule?  @relation("ScheduledInstances", fields: [scheduleId], references: [id])

  @@index([reportId])
  @@index([fiscalYearId])
  @@index([status])
  @@index([instanceNumber])
  @@map("fr_report_instances")
}

model FrReportInstanceRow {
  id              String            @id @default(uuid())
  instanceId      String
  instance        FrReportInstance  @relation(fields: [instanceId], references: [id])
  rowDefId        String?           @db.VarChar(36)
  parentRowId     String?           @db.VarChar(36)
  rowType         FrRowType
  rowCode         String?           @db.VarChar(20)
  label           String            @db.VarChar(255)
  displayOrder    Int               @default(0)
  indentLevel     Int               @default(0)
  isBold          Boolean           @default(false)

  // Values stored as JSON map of columnId -> value
  values          Json              @db.Json
  numericValues   Json?             @db.Json
  formattedValues Json?             @db.Json

  description     String?           @db.Text
  version         Int               @default(1)
  createdAt       DateTime          @default(now())

  @@index([instanceId])
  @@map("fr_instance_rows")
}

model FrConsolidationGroup {
  id              String                @id @default(uuid())
  code            String                @unique @db.VarChar(20)
  name            String                @db.VarChar(255)
  description     String?               @db.Text
  parentCompanyId String                @db.VarChar(36)
  currencyCode    String                @default("VND") @db.VarChar(3)
  isActive        Boolean               @default(true)
  version         Int                   @default(1)
  createdById     String                @db.VarChar(36)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  deletedAt       DateTime?

  members         FrConsolidationGroupMember[]
  runs            FrConsolidationRun[]

  @@index([code])
  @@map("fr_consolidation_groups")
}

model FrConsolidationGroupMember {
  id                  String                @id @default(uuid())
  groupId             String
  group               FrConsolidationGroup  @relation(fields: [groupId], references: [id])
  legalEntityId       String                @db.VarChar(36)
  legalEntityCode     String                @db.VarChar(20)
  legalEntityName     String                @db.VarChar(255)

  // Ownership
  ownershipPercentage Decimal               @db.Decimal(7, 4)
  consolidationMethod FrConsolidationMethod  @default(full)
  consolidationDate   DateTime
  deconsolidationDate DateTime?

  // Control
  isDirectControl     Boolean               @default(true)
  hasSignificantInfluence Boolean            @default(false)
  votingPercentage    Decimal?              @db.Decimal(7, 4)

  // Currency
  functionalCurrency  String                @default("VND") @db.VarChar(3)
  exchangeRateType    String                @default("closing") @db.VarChar(20)

  // Goodwill
  goodwillAmount      BigInt                @default(0)
  goodwillCurrency    String                @default("VND") @db.VarChar(3)
  impairmentAmount    BigInt                @default(0)

  // Status
  isActive            Boolean               @default(true)
  version             Int                   @default(1)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@unique([groupId, legalEntityId])
  @@index([groupId])
  @@map("fr_consolidation_members")
}

model FrConsolidationRun {
  id              String                 @id @default(uuid())
  groupId         String
  group           FrConsolidationGroup   @relation(fields: [groupId], references: [id])
  runNumber       String                 @unique @db.VarChar(50)
  status          FrConsolidationStatus  @default(draft)

  // Period
  fiscalYearId    String                 @db.VarChar(36)
  periodId        String?                @db.VarChar(36)
  periodNumber    Int
  periodName      String                 @db.VarChar(100)
  asOfDate        DateTime

  // Currency
  reportingCurrency String              @default("VND") @db.VarChar(3)
  exchangeRateDate  DateTime?

  // Audit
  preparedById    String                 @db.VarChar(36)
  reviewedById    String?                @db.VarChar(36)
  approvedById    String?                @db.VarChar(36)
  preparedAt      DateTime               @default(now())
  reviewedAt      DateTime?
  approvedAt      DateTime?
  lockedAt        DateTime?
  errorMessage    String?                @db.Text
  notes           String?                @db.Text

  version         Int                    @default(1)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  deletedAt       DateTime?

  entries         FrConsolidationEntry[]

  @@index([groupId])
  @@index([runNumber])
  @@index([status])
  @@map("fr_consolidation_runs")
}

model FrConsolidationEntry {
  id              String               @id @default(uuid())
  runId           String
  run             FrConsolidationRun   @relation(fields: [runId], references: [id])
  eliminationType FrEliminationType
  lineNumber      Int

  // Source entities
  fromEntityId    String?              @db.VarChar(36)
  toEntityId      String?              @db.VarChar(36)

  // Account mapping
  accountCode     String               @db.VarChar(20)
  accountName     String               @db.VarChar(255)

  // Amounts
  debitAmount     BigInt               @default(0)
  creditAmount    BigInt               @default(0)
  currencyCode    String               @default("VND") @db.VarChar(3)
  exchangeRate    Decimal              @default(1) @db.Decimal(19, 6)
  localAmount     BigInt               @default(0)

  // Automatic detection
  isAutoDetected  Boolean              @default(false)
  sourceBatchId   String?              @db.VarChar(36)
  sourceLineId    String?              @db.VarChar(36)

  // Audit
  description     String?              @db.Text
  reference       String?              @db.VarChar(100)
  createdById     String               @db.VarChar(36)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([runId])
  @@index([eliminationType])
  @@map("fr_consolidation_entries")
}

model FrReportingDimension {
  id              String                  @id @default(uuid())
  code            String                  @unique @db.VarChar(20)
  name            String                  @db.VarChar(255)
  dimensionType   FrReportingDimensionType
  parentId        String?
  parent          FrReportingDimension?   @relation("DimensionHierarchy", fields: [parentId], references: [id])
  children        FrReportingDimension[]  @relation("DimensionHierarchy")
  isActive        Boolean                 @default(true)
  displayOrder    Int                     @default(0)
  description     String?                 @db.Text
  version         Int                     @default(1)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([code])
  @@index([dimensionType])
  @@map("fr_reporting_dimensions")
}

model FrFinancialRatio {
  id              String            @id @default(uuid())
  code            String            @unique @db.VarChar(20)
  name            String            @db.VarChar(255)
  nameEn          String?           @db.VarChar(255)
  category        FrRatioCategory
  formula         String            @db.Text
  description     String?           @db.Text
  unit            String            @default("times") @db.VarChar(20)
  decimalPlaces   Int               @default(2)
  higherIsBetter  Boolean           @default(true)
  benchmarkValue  Decimal?          @db.Decimal(25, 6)
  minValue        Decimal?          @db.Decimal(25, 6)
  maxValue        Decimal?          @db.Decimal(25, 6)
  isActive        Boolean           @default(true)
  version         Int               @default(1)
  createdById     String            @db.VarChar(36)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  @@index([code])
  @@index([category])
  @@map("fr_financial_ratios")
}

model FrReportSchedule {
  id              String             @id @default(uuid())
  reportId        String
  report          FrReportDefinition @relation(fields: [reportId], references: [id])
  name            String             @db.VarChar(255)
  frequency       FrScheduleFrequency
  dayOfMonth      Int?               @default(1)
  dayOfWeek       Int?               @default(1)
  monthOfYear     Int?               @default(1)
  timeOfDay       String             @default("00:00") @db.VarChar(5)
  fiscalYearId    String?            @db.VarChar(36)
  legalEntityId   String?            @db.VarChar(36)
  consolidationGroupId String?       @db.VarChar(36)
  exportFormats   String             @default("PDF") @db.VarChar(100)
  recipientEmails String?            @db.Text
  isActive        Boolean            @default(true)
  nextRunAt       DateTime?
  lastRunAt       DateTime?
  version         Int                @default(1)
  createdById     String             @db.VarChar(36)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?

  instances FrReportInstance[]       @relation("ScheduledInstances")

  @@index([reportId])
  @@index([nextRunAt])
  @@map("fr_report_schedules")
}

model FrReportExport {
  id              String             @id @default(uuid())
  reportId        String
  report          FrReportDefinition @relation(fields: [reportId], references: [id])
  instanceId      String?            @db.VarChar(36)
  format          FrExportFormat
  config          Json?              @db.Json
  status          String             @default("pending") @db.VarChar(20)
  filePath        String?            @db.VarChar(500)
  fileSize        Int?               @default(0)
  errorMessage    String?            @db.Text
  generatedById   String             @db.VarChar(36)
  generatedAt     DateTime           @default(now())
  version         Int                @default(1)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([reportId])
  @@index([instanceId])
  @@index([format])
  @@map("fr_report_exports")
}

model FrReportApproval {
  id              String             @id @default(uuid())
  reportId        String
  report          FrReportDefinition @relation(fields: [reportId], references: [id])
  instanceId      String?            @db.VarChar(36)
  approvalType    String             @default("review") @db.VarChar(20)
  status          String             @default("pending") @db.VarChar(20)
  requestedById   String             @db.VarChar(36)
  requestedAt     DateTime           @default(now())
  approvedById    String?            @db.VarChar(36)
  approvedAt      DateTime?
  rejectedById    String?            @db.VarChar(36)
  rejectedAt      DateTime?
  rejectReason    String?            @db.Text
  comments        String?            @db.Text
  version         Int                @default(1)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([reportId])
  @@index([instanceId])
  @@index([status])
  @@map("fr_report_approvals")
}
