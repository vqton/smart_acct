  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  employees    PrlEmployeePayroll[]
  payrollRuns  PrlPayrollRun[]

  @@index([code])
  @@index([companyId])
  @@map("prl_payroll_groups")
}

model PrlSalaryComponent {
