  @@index([code])
  @@index([category])
  @@map("einv_invoice_types")
}

// ─── E-Invoice Template ────────────────────────────────────────────────────────

model EinvTemplate {
  id            String   @id @default(uuid())
  code          String   @unique @db.VarChar(20)
  name          String   @db.VarChar(255)
  description   String?  @db.Text
