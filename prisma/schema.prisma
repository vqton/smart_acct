  itemCode    String   @db.VarChar(50)
  unitPrice   BigInt   @default(0)
  minQuantity Decimal? @db.Decimal(18, 4)
  maxQuantity Decimal? @db.Decimal(18, 4)
  currencyCode String  @default("VND") @db.VarChar(3)
  effectiveFrom DateTime?
  effectiveTo  DateTime?
  isActive    Boolean  @default(true)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([priceListId])
  @@index([itemId])
  @@index([itemCode])
  @@map("sls_price_list_items")
}

// ─── Promotion ───────────────────────────────────────────────────────────────────

model SlsPromotion {
  id              String           @id @default(uuid())
  code            String           @unique @db.VarChar(20)
  name            String           @db.VarChar(255)
  promotionType   SlsPromotionType
  status          SlsPromotionStatus @default(draft)
  description     String?          @db.Text
  // Scope
  appliesTo       String           @default("all") @db.VarChar(20)
  customerGroupIds String?         @db.Text
  storeIds        String?          @db.Text
  itemIds         String?          @db.Text
  // Schedule
  startDate       DateTime
  endDate         DateTime
  // Value
  discountType    SlsDiscountType  @default(percentage)
  discountValue   Decimal          @default(0) @db.Decimal(19, 6)
  discountPercent Decimal          @default(0) @db.Decimal(5, 2)
  maxDiscount     BigInt?
  minOrderAmount  BigInt?
  maxQuantity     Int?
  // Budget
  budgetAmount    BigInt?
  usedAmount      BigInt           @default(0)
  usageLimit      Int?
  usageCount      Int              @default(0)
  perCustomerLimit Int?
  // Approval
  requiresApproval Boolean        @default(false)
  approvedBy      String?         @db.VarChar(100)
  approvedAt      DateTime?
  // Terms
  termsAndConditions String?       @db.Text
  // Metadata
  version         Int              @default(1)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  coupons     SlsCoupon[]
  orderLines  SlsOrderLinePromotion[]

  @@index([code])
  @@index([promotionType])
  @@index([status])
  @@index([startDate, endDate])
  @@map("sls_promotions")
}

model SlsCoupon {
  id            String          @id @default(uuid())
  code          String          @unique @db.VarChar(50)
  promotionId   String
  promotion     SlsPromotion    @relation(fields: [promotionId], references: [id])
  customerId    String?         @db.VarChar(36)
  status        SlsCouponStatus @default(active)
  discountType  SlsDiscountType @default(percentage)
  discountValue Decimal         @default(0) @db.Decimal(19, 6)
  discountPercent Decimal       @default(0) @db.Decimal(5, 2)
  maxDiscount   BigInt?
  minOrderAmount BigInt?
  validFrom     DateTime
  validTo       DateTime
  usageLimit    Int?
  usageCount    Int             @default(0)
  usedAt        DateTime?
  usedBy        String?         @db.VarChar(100)
  version       Int             @default(1)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  @@index([code])
  @@index([promotionId])
  @@index([customerId])
  @@index([status])
  @@map("sls_coupons")
}

