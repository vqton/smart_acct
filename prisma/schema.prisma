  postedToInventory   Boolean  @default(false)
  version             Int      @default(1)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  deletedAt           DateTime?

  @@index([importDeclarationId])
  @@map("pur_landed_costs")
}

// ─── Approval Workflow ────────────────────────────────────────────────────────────

model PurApprovalRequest {
