  calendarId  String
  calendar    BnkBusinessCalendar @relation(fields: [calendarId], references: [id])
  date        DateTime
  name        String   @db.VarChar(255)
  isRecurring Boolean  @default(false)
  isActive    Boolean  @default(true)

  @@unique([calendarId, date])
  @@index([date])
  @@map("bnk_calendar_holidays")
}
