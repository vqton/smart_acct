// ─── Employee Payroll Data ───────────────────────────────────────────────────

model PrlEmployeePayroll {
  id              String            @id @default(uuid())
  employeeCode    String            @unique @db.VarChar(50)
  employeeName    String            @db.VarChar(255)
  fullName        String?           @db.VarChar(255)
  gender          PrlGender?        @default(male)
  dateOfBirth     DateTime?
  identityNumber  String?           @db.VarChar(20)
  taxCode         String?           @db.VarChar(20)
  socialInsuranceNo String?         @db.VarChar(20)
  healthInsuranceNo String?         @db.VarChar(20)
  phone           String?           @db.VarChar(20)
  email           String?           @db.VarChar(255)
  address         String?           @db.VarChar(500)
  // Organization
  companyId       String            @db.VarChar(36)
  branchId        String?           @db.VarChar(36)
  departmentId    String?           @db.VarChar(36)
  divisionId      String?           @db.VarChar(36)
  sectionId       String?           @db.VarChar(36)
  positionId      String?           @db.VarChar(36)
  jobGradeId      String?           @db.VarChar(36)
  costCenterId    String?           @db.VarChar(36)
  // Payroll
  groupId         String            @db.VarChar(36)
  group           PrlPayrollGroup   @relation(fields: [groupId], references: [id])
  payFrequency    PrlPayFrequency?  @default(monthly)
  currencyCode    String            @default("VND") @db.VarChar(3)
  paymentMethod   PrlPaymentMethod  @default(bank_transfer)
  employmentType  PrlEmploymentType @default(indefinite)
  // Dates
  hireDate        DateTime
  contractEndDate DateTime?
  terminationDate DateTime?
  // Status
  isActive        Boolean           @default(true)
  isPITRegistered  Boolean          @default(false)
  isSIEnrolled    Boolean           @default(true)
  isHIEnrolled    Boolean           @default(true)
  isUIEnrolled    Boolean           @default(true)
  // Family deduction
  dependentCount  Int               @default(0)
  // Approval
  approvedById    String?           @db.VarChar(100)
  approvedAt      DateTime?
  // Audit
  version         Int               @default(1)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  salaries        PrlEmployeeSalary[]
  dependents      PrlEmployeeDependent[]
  bankAccounts    PrlEmployeeBankAccount[]
  payrollLines    PrlPayrollLine[]
  attendance      PrlAttendanceRecord[]
  overtime        PrlOvertimeRecord[]
  leaveRecords    PrlLeaveRecord[]

  @@index([employeeCode])
  @@index([companyId])
  @@index([branchId])
  @@index([groupId])
  @@index([departmentId])
  @@index([costCenterId])
  @@index([isActive])
  @@index([taxCode])
  @@map("prl_employee_payrolls")
}

model PrlEmployeeSalary {
  id              String            @id @default(uuid())
  employeeId      String            @db.VarChar(36)
  employee        PrlEmployeePayroll @relation(fields: [employeeId], references: [id])
  componentId     String            @db.VarChar(36)
  component       PrlSalaryComponent @relation(fields: [componentId], references: [id])
  amount          BigInt            @default(0)
  currencyCode    String            @default("VND") @db.VarChar(3)
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  isActive        Boolean           @default(true)
  version         Int               @default(1)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  @@index([employeeId])
  @@index([componentId])
  @@index([effectiveFrom])
  @@unique([employeeId, componentId, effectiveFrom])
  @@map("prl_employee_salaries")
}

model PrlEmployeeDependent {
  id              String   @id @default(uuid())
  employeeId      String   @db.VarChar(36)
  employee        PrlEmployeePayroll @relation(fields: [employeeId], references: [id])
  fullName        String   @db.VarChar(255)
  dateOfBirth     DateTime?
  relationship    String   @db.VarChar(50)
  taxCode         String?  @db.VarChar(20)
  identificationNo String? @db.VarChar(20)
  isRegistered    Boolean  @default(false)
  registrationDate DateTime?
  isActive        Boolean  @default(true)
  version         Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@index([employeeId])
  @@map("prl_employee_dependents")
}

model PrlEmployeeBankAccount {
  id            String             @id @default(uuid())
  employeeId    String             @db.VarChar(36)
  employee      PrlEmployeePayroll @relation(fields: [employeeId], references: [id])
  bankName      String             @db.VarChar(255)
  bankBranch    String?            @db.VarChar(255)
  accountNumber String             @db.VarChar(50)
  accountName   String             @db.VarChar(255)
  isDefault     Boolean            @default(false)
  isActive      Boolean            @default(true)
  version       Int                @default(1)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?

  @@index([employeeId])
  @@map("prl_employee_bank_accounts")
}

// ─── Attendance & Time ───────────────────────────────────────────────────────

model PrlAttendanceRecord {
  id          String   @id @default(uuid())
  employeeId  String   @db.VarChar(36)
