// ─── Accounts Receivable ─────────────────────────────────────────────────────────

model SlsReceivableAccount {
  id                String   @id @default(uuid())
  customerId        String
  invoiceId         String   @db.VarChar(36)
  invoiceNumber     String   @db.VarChar(100)
  companyId         String   @db.VarChar(36)
  branchId          String?  @db.VarChar(36)
  // Amounts
  originalAmount    BigInt   @default(0)
  outstandingAmount BigInt   @default(0)
  paidAmount        BigInt   @default(0)
  discountedAmount  BigInt   @default(0)
  writtenOffAmount  BigInt   @default(0)
  currencyCode      String   @default("VND") @db.VarChar(3)
  exchangeRate      Decimal  @default(1) @db.Decimal(18, 6)
  // Dates
  invoiceDate       DateTime
  dueDate           DateTime
  lastPaymentDate   DateTime?
  // Aging
  agingDays         Int      @default(0)
  agingBucket       String?  @db.VarChar(20)
  // Status
  status            String   @default("outstanding") @db.VarChar(20)
  isOverdue         Boolean  @default(false)
  isDisputed        Boolean  @default(false)
  // Dunning
  dunningLevel      Int      @default(0)
  lastDunningDate   DateTime?
  dunningCount      Int      @default(0)
  // Collection
  assignedCollector String?  @db.VarChar(100)
  promiseDate       DateTime?
  promiseAmount     BigInt   @default(0)
  // Write-off
  writtenOffAt      DateTime?
  writeOffReason    String?  @db.Text
  approvedBy        String?  @db.VarChar(100)
  // Bad Debt
  isBadDebt         Boolean  @default(false)
  badDebtAmount     BigInt   @default(0)
  badDebtProvision  BigInt   @default(0)
  // GL
  glBatchId         String?  @db.VarChar(36)
  postedToGL        Boolean  @default(false)
  // Audit
  version           Int      @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  @@index([customerId])
  @@index([invoiceId])
  @@index([status])
  @@index([dueDate])
  @@index([agingBucket])
  @@index([companyId])
  @@index([isOverdue])
  @@map("sls_receivable_accounts")
}

