enum PurVendorStatus {
  active
  inactive
  blocked
  suspended
  pending
}

enum PurVendorType {
  individual
  company
  government
  non_profit
  foreign
}

enum PurRequisitionStatus {
  draft
  submitted
  approved
  rejected
  partially_ordered
  fully_ordered
  cancelled
}

enum PurRFQStatus {
  draft
  sent
  responses_received
  evaluated
  awarded
  cancelled
}

enum PurPOStatus {
  draft
  pending_approval
  approved
  sent
  confirmed
  partly_received
  fully_received
  partly_invoiced
  fully_invoiced
  closed
  cancelled
  on_hold
}

enum PurPOType {
  standard
  blanket
  framework
  contract
  service
  consignment
  drop_shipment
  emergency
  recurring
}

enum PurContractStatus {
  draft
  active
  expired
  terminated
  amended
}

enum PurReceiptStatus {
  expected
  partly_received
  fully_received
  reversed
  cancelled
}

enum PurInvoiceStatus {
  draft
  registered
  verified
  approved
  paid
  partially_paid
  cancelled
  on_hold
}

enum PurInvoiceMatchStatus {
  unmatched
  partially_matched
  fully_matched
  exception
}

enum PurImportStatus {
  declared
  customs_cleared
  goods_released
  duty_paid
  completed
}

enum PurApprovalStatus {
  pending
  approved
  rejected
  returned
  delegated
  escalated
}

