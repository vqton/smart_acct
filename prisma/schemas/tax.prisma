enum TaxCategory {
  value_added_tax
  corporate_income_tax
  personal_income_tax
  special_consumption_tax
  natural_resource_tax
  environmental_tax
  customs_duty
  land_tax
  license_tax
  other
}

enum TaxRateType {
  percentage
  fixed_amount
  mixed
}

enum TaxApplication {
  sales
  purchases
  imports
  exports
  both
}

enum TaxBasis {
  revenue
  profit
  salary
  consumption
  resource_volume
  land_area
  customs_value
  other
}

enum TaxCalculationMethod {
  direct
  deduction
  withholding
  presumptive
  hybrid
}

enum TaxPaymentMethod {
  monthly
  quarterly
  annual
  per_transaction
  withholding
}

enum TaxFilingFrequency {
  monthly
  quarterly
  annual
  per_transaction
}

enum TaxRegistrationStatus {
  draft
  submitted
  active
  suspended
  cancelled
  closed
}

enum TaxReturnStatus {
  draft
  prepared
  submitted
  accepted
  rejected
  amended
  closed
}

enum TaxReturnType {
  original
  amended
  supplementary
  final
}

enum TaxExemptionType {
  full_exemption
  partial_exemption
  reduced_rate
  tax_holiday
  investment_incentive
  export_incentive
  special_economic_zone
}

enum TaxExemptionStatus {
  active
  used
  expired
  revoked
}

enum TaxPaymentStatus {
  pending
  due
  paid
  overdue
  partially_paid
  refunded
  cancelled
  fully_refunded
  failed
}

model TaxType {
  id                  String          @id @default(uuid())
  code                String          @unique @db.VarChar(20)
  name                String          @db.VarChar(255)
  nameEn              String?         @db.VarChar(255)
  category            TaxCategory
  nature              String          @db.VarChar(20)
  basis               TaxBasis
  calculationMethod   TaxCalculationMethod @map("calculation_method")
  paymentMethod       TaxPaymentMethod     @map("payment_method")
  filingFrequency     TaxFilingFrequency   @map("filing_frequency")
  description         String?         @db.Text
  legalReference      String?         @db.VarChar(255)
  isActive            Boolean         @default(true) @map("is_active")
  requiresRegistration Boolean        @default(true)
  requiresDeclaration  Boolean        @default(true)
  requiresPayment     Boolean         @default(true)
  hasWithholding      Boolean         @default(false)
  hasExemption        Boolean         @default(false)
  hasIncentive        Boolean         @default(false)
  priority            Int             @default(0)
  parentTaxTypeId     String?         @map("parent_tax_type_id")
  version             Int             @default(1)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  codes               TaxCode[]
  registrations       TaxRegistration[]
  returns             TaxReturn[]
  exemptions          TaxExemption[]
  payments            TaxPayment[]
  determinationRules  TaxDeterminationRule[]

  @@index([category])
  @@index([isActive])
  @@map("tax_types")
}

model TaxCode {
  id                  String          @id @default(uuid())
  code                String          @unique @db.VarChar(20)
  name                String          @db.VarChar(255)
  taxTypeId           String
  taxType             TaxType         @relation(fields: [taxTypeId], references: [id])
  taxRateType         TaxRateType     @map("tax_rate_type")
  application         TaxApplication
  roundingMethod      String          @default("round")
  precision           Int             @default(0)
  description         String?         @db.Text
  isActive            Boolean         @default(true)
  isRecoverable       Boolean         @default(true)
  isRefundable        Boolean         @default(false)
  isDeductible        Boolean         @default(true)
  glTaxAccountId      String?         @map("gl_tax_account_id")
  glRecoverableAccountId String?      @map("gl_recoverable_account_id")
  glExpenseAccountId  String?         @map("gl_expense_account_id")
  effectiveFrom       DateTime
  effectiveTo         DateTime?
  version             Int             @default(1)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  rates               TaxRate[]
  exemptions          TaxExemption[]

  @@index([taxTypeId])
  @@map("tax_codes")
}

model TaxRate {
  id                  String          @id @default(uuid())
  taxCodeId           String
  taxCode             TaxCode         @relation(fields: [taxCodeId], references: [id])
  rate                Decimal         @db.Decimal(19, 6)
  rateType            TaxRateType     @default(percentage)
  minimumAmount       BigInt?
  maximumAmount       BigInt?
  effectiveFrom       DateTime
  effectiveTo         DateTime?
  priority            Int             @default(0)
  isActive            Boolean         @default(true)
  version             Int             @default(1)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([taxCodeId])
  @@index([taxCodeId, effectiveFrom, effectiveTo])
  @@map("tax_rates")
}

model TaxAuthority {
  id                  String          @id @default(uuid())
  code                String          @unique @db.VarChar(20)
  name                String          @db.VarChar(255)
  taxOfficeCode       String          @db.VarChar(20)
  jurisdictionLevel   String          @db.VarChar(20)
  parentId            String?
  parent              TaxAuthority?   @relation("TaxAuthorityHierarchy", fields: [parentId], references: [id])
  children            TaxAuthority[]  @relation("TaxAuthorityHierarchy")
  address             String?         @db.Text
  phone               String?         @db.VarChar(20)
  email               String?         @db.VarChar(255)
  website             String?         @db.VarChar(255)
  isActive            Boolean         @default(true)
  version             Int             @default(1)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([jurisdictionLevel])
  @@map("tax_authorities")
}

model TaxRegion {
  id                  String          @id @default(uuid())
  code                String          @unique @db.VarChar(20)
  name                String          @db.VarChar(255)
  type                String          @db.VarChar(30)
  provinceCode        String?         @db.VarChar(10)
  districtCode        String?         @db.VarChar(10)
  wardCode            String?         @db.VarChar(10)
  isActive            Boolean         @default(true)
  version             Int             @default(1)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([type])
  @@index([provinceCode])
  @@map("tax_regions")
}

model TaxRegistration {
  id                  String              @id @default(uuid())
  registrationNumber  String              @unique @db.VarChar(50)
  taxpayerId          String              @db.VarChar(36)
  taxpayerName        String              @db.VarChar(255)
  taxTypeId           String
  taxType             TaxType             @relation(fields: [taxTypeId], references: [id])
  taxAuthorityId      String?
  status              TaxRegistrationStatus @default(draft)
  registrationDate    DateTime?
  deregistrationDate  DateTime?
  suspensionDate      DateTime?
  reason              String?             @db.Text
  submittedById       String?
  approvedById        String?
  approvedAt          DateTime?
  description         String?             @db.Text
  version             Int                 @default(1)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([taxpayerId])
  @@index([taxTypeId])
  @@index([status])
  @@map("tax_registrations")
}

model TaxExemption {
  id                  String              @id @default(uuid())
  code                String              @unique @db.VarChar(50)
  name                String              @db.VarChar(255)
  exemptionType       TaxExemptionType
  status              TaxExemptionStatus  @default(active)
  taxTypeId           String
  taxType             TaxType             @relation(fields: [taxTypeId], references: [id])
  taxCodeId           String?
  taxCode             TaxCode?            @relation(fields: [taxCodeId], references: [id])
  taxpayerId          String?             @db.VarChar(36)
  exemptPercentage    Decimal?            @db.Decimal(5, 2)
  exemptAmount        BigInt?
  maxAmount           BigInt?
  validFrom           DateTime
  validTo             DateTime?
  issuingAuthority    String?             @db.VarChar(255)
  referenceNumber     String?             @db.VarChar(100)
  reason              String?             @db.Text
  description         String?             @db.Text
  version             Int                 @default(1)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([taxTypeId])
  @@index([taxpayerId])
  @@index([status])
  @@map("tax_exemptions")
}

model TaxReturn {
  id                  String              @id @default(uuid())
  returnNumber        String              @unique @db.VarChar(50)
  returnType          TaxReturnType       @default(original)
  status              TaxReturnStatus     @default(draft)
  taxTypeId           String
  taxType             TaxType             @relation(fields: [taxTypeId], references: [id])
  taxpayerId          String              @db.VarChar(36)
  taxpayerName        String              @db.VarChar(255)
  periodId            String              @db.VarChar(36)
  periodName          String              @db.VarChar(100)
  fiscalYearId        String
  totalTaxAmount      BigInt              @default(0)
  totalPaidAmount     BigInt              @default(0)
  totalDueAmount      BigInt              @default(0)
  totalCreditAmount   BigInt              @default(0)
  currencyCode        String              @default("VND") @db.VarChar(3)
  exchangeRate        Decimal             @default(1.0) @db.Decimal(19, 6)
  originalReturnId    String?
  submittedById       String?
  submittedAt         DateTime?
  approvedById        String?
  approvedAt          DateTime?
  description         String?             @db.Text
  version             Int                 @default(1)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  payments            TaxPayment[]

  @@index([taxpayerId])
  @@index([taxTypeId])
  @@index([status])
  @@index([periodId])
  @@map("tax_returns")
}

model TaxPayment {
  id                  String              @id @default(uuid())
  paymentNumber       String              @unique @db.VarChar(50)
  taxReturnId         String?
  taxReturn           TaxReturn?          @relation(fields: [taxReturnId], references: [id])
  taxTypeId           String
  taxType             TaxType             @relation(fields: [taxTypeId], references: [id])
  taxpayerId          String              @db.VarChar(36)
  amount              BigInt              @default(0)
  paidAmount          BigInt              @default(0)
  refundAmount        BigInt              @default(0)
  status              TaxPaymentStatus    @default(pending)
  paymentDate         DateTime?
  dueDate             DateTime?
  paymentMethod       String?             @db.VarChar(50)
  reference           String?             @db.VarChar(100)
  bankAccount         String?             @db.VarChar(50)
  glBatchId           String?
  description         String?             @db.Text
  version             Int                 @default(1)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([taxReturnId])
  @@index([taxpayerId])
  @@index([status])
  @@map("tax_payments")
}

model TaxDeterminationRule {
  id                  String          @id @default(uuid())
  taxTypeId           String
  taxType             TaxType         @relation(fields: [taxTypeId], references: [id])
  ruleOrder           Int
  conditionField      String          @db.VarChar(50)
  conditionOperator   String          @db.VarChar(20)
  conditionValue      String          @db.VarChar(255)
  resultTaxCodeId     String?         @db.VarChar(36)
  resultRate          Decimal?        @db.Decimal(19, 6)
  effectiveFrom       DateTime
  effectiveTo         DateTime?
  description         String?         @db.Text
  isActive            Boolean         @default(true)
  version             Int             @default(1)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([taxTypeId])
  @@index([effectiveFrom, effectiveTo])
  @@map("tax_determination_rules")
}
