// ─── Inventory Module ─────────────────────────────────────────────────────────

enum InvItemType {
  inventory
  service
  non_stock
  consignment
  fixed_asset
}

enum InvItemStatus {
  active
  inactive
  discontinued
  obsolete
}

enum InvItemCategory {
  raw_material
  semi_finished
  finished_good
  wip
  packaging
  supplies
  trading
  service
  asset
}

enum InvValuationMethod {
  fifo
  moving_average
  weighted_average
  standard
  specific_identification
}

enum InvLotControl {
  none
  lot
  serial
  both
}

enum InvWarehouseType {
  main
  distribution_center
  store
  transit
  consignment
  virtual
}

enum InvWarehouseStatus {
  active
  inactive
  closed
}

enum InvLocationType {
  zone
  area
  aisle
  rack
  shelf
  bin
  dock
  staging
  quarantine
}

enum InvLocationStatus {
  active
  inactive
  blocked
  full
}

enum InvStorageType {
  dry
  cold
  frozen
  hazardous
  climate_controlled
}

enum InvTransactionType {
  goods_receipt
  goods_issue
  transfer_out
  transfer_in
  adjustment_increase
  adjustment_decrease
  write_off
  write_on
  return_to_vendor
  customer_return
  production_consumption
  production_receipt
  scrap
  sample
  promotional
  internal_consumption
  opening_balance
  reversal
  revaluation
  landed_cost
}

enum InvTransactionStatus {
  draft
  submitted
  approved
  posted
  reversed
  cancelled
}

enum InvStockStatus {
  available
  reserved
  allocated
  in_transit
  on_order
  quarantine
  quality_hold
  inspection_hold
  blocked
  damaged
  returned
}

enum InvCountStatus {
  planned
  in_progress
  frozen
  completed
  approved
  cancelled
}

enum InvCountType {
  physical
  cycle
  blind
  spot
  annual
}

enum InvReservationStatus {
  active
  partially_fulfilled
  fulfilled
  cancelled
  expired
}

enum InvCostMethod {
  fifo
  moving_average
  weighted_average
  standard
  specific_id
}

enum InvQualityStatus {
  not_inspected
  passed
  failed
  on_hold
  quarantine
}

model InvItem {
  id                   String          @id @default(uuid())
  code                 String          @unique @db.VarChar(50)
  sku                  String          @unique @db.VarChar(100)
  barcode              String?         @unique @db.VarChar(100)
  plu                  String?         @db.VarChar(50)
  name                 String          @db.VarChar(255)
  nameEn               String?         @db.VarChar(255)
  description          String?         @db.Text
  itemType             InvItemType     @default(inventory)
  status               InvItemStatus   @default(active)
  category             InvItemCategory @default(trading)
  itemGroupId          String?         @db.VarChar(36)
  brandId              String?         @db.VarChar(36)
  uomId                String          @db.VarChar(36)
  valuationMethod      InvValuationMethod @default(moving_average)
  lotControl           InvLotControl   @default(none)
  shelfLifeDays        Int?
  isHazardous          Boolean         @default(false)
  isConsignment        Boolean         @default(false)
  isSerialized         Boolean         @default(false)
  isLotControlled      Boolean         @default(false)
  dimensions           String?         @db.Text
  taxCodeId            String?
  glInventoryAccountId String?         @db.VarChar(36)
  glRevenueAccountId   String?         @db.VarChar(36)
  glCogsAccountId      String?         @db.VarChar(36)
  glExpenseAccountId   String?         @db.VarChar(36)
  glPurchaseAccountId  String?         @db.VarChar(36)
  glTransferAccountId  String?         @db.VarChar(36)
  standardCost         Decimal?        @db.Decimal(19, 4)
  minStock             Decimal?        @db.Decimal(19, 4)
  maxStock             Decimal?        @db.Decimal(19, 4)
  reorderPoint         Decimal?        @db.Decimal(19, 4)
  leadTimeDays         Int?
  version              Int             @default(1)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  deletedAt            DateTime?

  balances         InvStockBalance[]
  costLayers       InvCostLayer[]
  countLines       InvCountLine[]
  reservationLines InvReservationLine[]
  transactionLines InvTransactionLine[]
  qualityInspections InvQualityInspection[]

  @@index([code])
  @@index([sku])
  @@index([barcode])
  @@index([status])
  @@index([category])
  @@index([itemGroupId])
  @@index([brandId])
  @@map("inv_items")
}

model InvUom {
  id             String   @id @default(uuid())
  code           String   @unique @db.VarChar(20)
  name           String   @db.VarChar(100)
  decimalPlaces  Int      @default(2)
  isActive       Boolean  @default(true)
  version        Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversionsFrom InvUomConversion[] @relation("UomConversionFrom")
  conversionsTo   InvUomConversion[] @relation("UomConversionTo")

  @@index([code])
  @@map("inv_uoms")
}

model InvUomConversion {
  id             String  @id @default(uuid())
  fromUomId      String  @db.VarChar(36)
  toUomId        String  @db.VarChar(36)
  conversionRate Decimal @db.Decimal(19, 6)
  isActive       Boolean @default(true)

  fromUom InvUom @relation("UomConversionFrom", fields: [fromUomId], references: [id])
  toUom   InvUom @relation("UomConversionTo", fields: [toUomId], references: [id])

  @@unique([fromUomId, toUomId])
  @@map("inv_uom_conversions")
}

model InvWarehouse {
  id              String            @id @default(uuid())
  code            String            @unique @db.VarChar(20)
  name            String            @db.VarChar(255)
  type            InvWarehouseType  @default(main)
  status          InvWarehouseStatus @default(active)
  address         String?           @db.VarChar(500)
  city            String?           @db.VarChar(100)
  district        String?           @db.VarChar(100)
  ward            String?           @db.VarChar(100)
  country         String            @default("VN") @db.VarChar(3)
  companyId       String            @db.VarChar(36)
  branchId        String?           @db.VarChar(36)
  isActive        Boolean           @default(true)
  allowNegative   Boolean           @default(false)
  capacityWeight  Decimal?          @db.Decimal(19, 4)
  capacityVolume  Decimal?          @db.Decimal(19, 4)
  storageType     InvStorageType    @default(dry)
  calendarId      String?           @db.VarChar(36)
  latitude        Decimal?          @db.Decimal(10, 7)
  longitude       Decimal?          @db.Decimal(10, 7)
  phone           String?           @db.VarChar(50)
  email           String?           @db.VarChar(255)
  managerName     String?           @db.VarChar(255)
  notes           String?           @db.Text
  version         Int               @default(1)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  locations   InvLocation[]
  balances    InvStockBalance[]
  transactions InvTransaction[]
  countSheets InvStockCount[]
  costLayers  InvCostLayer[]

  @@index([code])
  @@index([type])
  @@index([status])
  @@index([companyId])
  @@index([branchId])
  @@map("inv_warehouses")
}

model InvLocation {
  id            String           @id @default(uuid())
  warehouseId   String           @db.VarChar(36)
  parentId      String?          @db.VarChar(36)
  code          String           @db.VarChar(50)
  name          String           @db.VarChar(255)
  type          InvLocationType  @default(bin)
  status        InvLocationStatus @default(active)
  storageType   InvStorageType   @default(dry)
  isActive      Boolean          @default(true)
  maxWeight     Decimal?         @db.Decimal(19, 4)
  maxVolume     Decimal?         @db.Decimal(19, 4)
  maxPalletCount Int?
  barcode       String?          @db.VarChar(100)
  putawayZone   String?          @db.VarChar(50)
  pickingZone   String?          @db.VarChar(50)
  x             Decimal?         @db.Decimal(10, 4)
  y             Decimal?         @db.Decimal(10, 4)
  z             Decimal?         @db.Decimal(10, 4)
  notes         String?          @db.Text
  version       Int              @default(1)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  warehouse InvWarehouse @relation(fields: [warehouseId], references: [id], map: "inv_loc_warehouse_fk")

  @@unique([warehouseId, code])
  @@index([warehouseId])
  @@index([type])
  @@index([status])
  @@index([putawayZone])
  @@index([pickingZone])
  @@map("inv_locations")
}

model InvStockBalance {
  id               String        @id @default(uuid())
  itemId           String        @db.VarChar(36)
  warehouseId      String        @db.VarChar(36)
  locationId       String?       @db.VarChar(36)
  lotId            String?       @db.VarChar(36)
  stockStatus      InvStockStatus @default(available)
  quantity         Decimal       @default(0) @db.Decimal(19, 4)
  reservedQty      Decimal       @default(0) @db.Decimal(19, 4)
  allocatedQty     Decimal       @default(0) @db.Decimal(19, 4)
  inTransitQty     Decimal       @default(0) @db.Decimal(19, 4)
  onOrderQty       Decimal       @default(0) @db.Decimal(19, 4)
  unitCost         Decimal       @default(0) @db.Decimal(19, 4)
  totalCost        Decimal       @default(0) @db.Decimal(19, 4)
  currencyCode     String        @default("VND") @db.VarChar(3)
  lastTransactionAt DateTime?
  version          Int           @default(1)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  item      InvItem      @relation(fields: [itemId], references: [id], map: "inv_sb_item_fk")
  warehouse InvWarehouse @relation(fields: [warehouseId], references: [id], map: "inv_sb_warehouse_fk")

  @@unique([itemId, warehouseId, locationId, lotId])
  @@index([itemId])
  @@index([warehouseId])
  @@index([stockStatus])
  @@index([itemId, stockStatus])
  @@map("inv_stock_balances")
}

model InvTransaction {
  id                  String              @id @default(uuid())
  transactionNumber   String              @unique @db.VarChar(50)
  transactionType     InvTransactionType
  status              InvTransactionStatus @default(draft)
  companyId           String              @db.VarChar(36)
  branchId            String?             @db.VarChar(36)
  warehouseId         String              @db.VarChar(36)
  transactionDate     DateTime
  postingDate         DateTime
  currencyCode        String              @default("VND") @db.VarChar(3)
  exchangeRate        Decimal             @default(1) @db.Decimal(19, 6)
  totalQuantity       Decimal             @default(0) @db.Decimal(19, 4)
  totalAmount         Decimal             @default(0) @db.Decimal(19, 4)
  description         String?             @db.Text
  referenceType       String?             @db.VarChar(50)
  referenceId         String?             @db.VarChar(36)
  sourceDocumentType  String?             @db.VarChar(50)
  sourceDocumentId    String?             @db.VarChar(36)
  createdById         String?             @db.VarChar(36)
  approvedById        String?             @db.VarChar(36)
  approvedAt          DateTime?
  postedById          String?             @db.VarChar(36)
  postedAt            DateTime?
  reversedById        String?             @db.VarChar(36)
  reversedAt          DateTime?
  reverseOfId         String?             @db.VarChar(36)
  cancelledById       String?             @db.VarChar(36)
  cancelledAt         DateTime?
  cancelReason        String?             @db.Text
  version             Int                 @default(1)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  warehouse InvWarehouse @relation(fields: [warehouseId], references: [id], map: "inv_tx_warehouse_fk")
  lines     InvTransactionLine[]

  @@index([transactionNumber])
  @@index([transactionType])
  @@index([status])
  @@index([warehouseId])
  @@index([transactionDate])
  @@index([postingDate])
  @@index([referenceType, referenceId])
  @@index([sourceDocumentType, sourceDocumentId])
  @@map("inv_transactions")
}

model InvTransactionLine {
  id              String   @id @default(uuid())
  transactionId   String   @db.VarChar(36)
  lineNumber      Int
  itemId          String   @db.VarChar(36)
  warehouseId     String   @db.VarChar(36)
  locationId      String?  @db.VarChar(36)
  lotId           String?  @db.VarChar(36)
  serialNumber    String?  @db.VarChar(100)
  quantity        Decimal  @db.Decimal(19, 4)
  unitCost        Decimal  @db.Decimal(19, 4)
  totalCost       Decimal  @db.Decimal(19, 4)
  currencyCode    String   @default("VND") @db.VarChar(3)
  exchangeRate    Decimal  @default(1) @db.Decimal(19, 6)
  referenceType   String?  @db.VarChar(50)
  referenceId     String?  @db.VarChar(36)
  description     String?  @db.Text

  transaction InvTransaction @relation(fields: [transactionId], references: [id], map: "inv_txl_tx_fk")
  item        InvItem       @relation(fields: [itemId], references: [id], map: "inv_txl_item_fk")

  @@index([transactionId])
  @@index([itemId])
  @@index([lotId])
  @@index([referenceType, referenceId])
  @@map("inv_transaction_lines")
}

model InvCostLayer {
  id                      String          @id @default(uuid())
  itemId                  String          @db.VarChar(36)
  warehouseId             String          @db.VarChar(36)
  lotId                   String?         @db.VarChar(36)
  costMethod              InvCostMethod   @default(fifo)
  quantity                Decimal         @db.Decimal(19, 4)
  unitCost                Decimal         @db.Decimal(19, 4)
  totalCost               Decimal         @db.Decimal(19, 4)
  remainingQty            Decimal         @db.Decimal(19, 4)
  remainingCost           Decimal         @db.Decimal(19, 4)
  receivedAt              DateTime
  transactionId           String          @db.VarChar(36)
  transactionLineId       String?         @db.VarChar(36)
  isConsumed              Boolean         @default(false)
  consumedAt              DateTime?
  consumedByTransactionId String?         @db.VarChar(36)
  version                 Int             @default(1)
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  item      InvItem      @relation(fields: [itemId], references: [id], map: "inv_cl_item_fk")
  warehouse InvWarehouse @relation(fields: [warehouseId], references: [id], map: "inv_cl_warehouse_fk")

  @@index([itemId, warehouseId])
  @@index([itemId, warehouseId, isConsumed])
  @@index([itemId, warehouseId, remainingQty])
  @@map("inv_cost_layers")
}

model InvStockCount {
  id           String        @id @default(uuid())
  countNumber  String        @unique @db.VarChar(50)
  countType    InvCountType  @default(physical)
  status       InvCountStatus @default(planned)
  companyId    String        @db.VarChar(36)
  warehouseId  String        @db.VarChar(36)
  locationId   String?       @db.VarChar(36)
  countedAt    DateTime?
  frozenAt     DateTime?
  completedAt  DateTime?
  approvedAt   DateTime?
  approvedById String?       @db.VarChar(36)
  cancelledAt  DateTime?
  cancelReason String?       @db.Text
  notes        String?       @db.Text
  version      Int           @default(1)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  warehouse InvWarehouse @relation(fields: [warehouseId], references: [id], map: "inv_sc_warehouse_fk")
  lines     InvCountLine[]

  @@index([countNumber])
  @@index([status])
  @@index([warehouseId])
  @@index([countType])
  @@map("inv_stock_counts")
}

model InvCountLine {
  id           String   @id @default(uuid())
  countId      String   @db.VarChar(36)
  lineNumber   Int
  itemId       String   @db.VarChar(36)
  warehouseId  String   @db.VarChar(36)
  locationId   String?  @db.VarChar(36)
  lotId        String?  @db.VarChar(36)
  expectedQty  Decimal  @db.Decimal(19, 4)
  actualQty    Decimal? @db.Decimal(19, 4)
  varianceQty  Decimal  @default(0) @db.Decimal(19, 4)
  varianceValue Decimal @default(0) @db.Decimal(19, 4)
  unitCost     Decimal  @default(0) @db.Decimal(19, 4)
  isCounted    Boolean  @default(false)
  isApproved   Boolean  @default(false)
  notes        String?  @db.Text
  countedById  String?  @db.VarChar(36)
  countedAt    DateTime?

  stockCount InvStockCount @relation(fields: [countId], references: [id], map: "inv_cline_count_fk")
  item       InvItem       @relation(fields: [itemId], references: [id], map: "inv_cline_item_fk")

  @@index([countId])
  @@index([itemId])
  @@map("inv_count_lines")
}

model InvReservation {
  id                String               @id @default(uuid())
  reservationNumber String               @unique @db.VarChar(50)
  status            InvReservationStatus @default(active)
  orderType         String               @db.VarChar(50)
  orderId           String               @db.VarChar(36)
  orderLineId       String?              @db.VarChar(36)
  companyId         String               @db.VarChar(36)
  customerId        String?              @db.VarChar(36)
  warehouseId       String?              @db.VarChar(36)
  reservedAt        DateTime             @default(now())
  expiresAt         DateTime?
  fulfilledAt       DateTime?
  cancelledAt       DateTime?
  cancelReason      String?              @db.Text
  version           Int                  @default(1)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  lines InvReservationLine[]

  @@index([reservationNumber])
  @@index([status])
  @@index([orderType, orderId])
  @@index([expiresAt])
  @@map("inv_reservations")
}

model InvReservationLine {
  id             String   @id @default(uuid())
  reservationId  String   @db.VarChar(36)
  lineNumber     Int
  itemId         String   @db.VarChar(36)
  warehouseId    String   @db.VarChar(36)
  locationId     String?  @db.VarChar(36)
  lotId          String?  @db.VarChar(36)
  quantity       Decimal  @db.Decimal(19, 4)
  fulfilledQty   Decimal  @default(0) @db.Decimal(19, 4)
  cancelledQty   Decimal  @default(0) @db.Decimal(19, 4)

  reservation InvReservation @relation(fields: [reservationId], references: [id], map: "inv_rl_resv_fk")
  item         InvItem       @relation(fields: [itemId], references: [id], map: "inv_rl_item_fk")

  @@index([reservationId])
  @@index([itemId])
  @@map("inv_reservation_lines")
}

model InvQualityInspection {
  id            String           @id @default(uuid())
  inspectionNo  String           @unique @db.VarChar(50)
  itemId        String           @db.VarChar(36)
  lotId         String?          @db.VarChar(36)
  transactionId String?          @db.VarChar(36)
  inspectorId   String?          @db.VarChar(36)
  status        InvQualityStatus @default(not_inspected)
  result        String?          @db.Text
  notes         String?          @db.Text
  inspectedAt   DateTime?
  version       Int              @default(1)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  item InvItem @relation(fields: [itemId], references: [id], map: "inv_qi_item_fk")

  @@index([inspectionNo])
  @@index([itemId])
  @@index([status])
  @@map("inv_quality_inspections")
}

model InvSerialNumber {
  id            String    @id @default(uuid())
  serialNumber  String    @unique @db.VarChar(100)
  itemId        String    @db.VarChar(36)
  warehouseId   String    @db.VarChar(36)
  locationId    String?   @db.VarChar(36)
  status        String    @default("available") @db.VarChar(20)
  transactionId String?   @db.VarChar(36)
  soldAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([serialNumber])
  @@index([itemId])
  @@index([status])
  @@map("inv_serial_numbers")
}
