// ═══════════════════════════════════════════════════════════════════════════════
// PURCHASING MODULE (Procure-to-Pay)
// ═══════════════════════════════════════════════════════════════════════════════

enum PurVendorStatus {
  active
  inactive
  blocked
  suspended
  pending
}

enum PurVendorType {
  individual
  company
  government
  non_profit
  foreign
}

enum PurRequisitionStatus {
  draft
  submitted
  approved
  rejected
  partially_ordered
  fully_ordered
  cancelled
}

enum PurRFQStatus {
  draft
  sent
  responses_received
  evaluated
  awarded
  cancelled
}

enum PurPOStatus {
  draft
  pending_approval
  approved
  sent
  confirmed
  partly_received
  fully_received
  partly_invoiced
  fully_invoiced
  closed
  cancelled
  on_hold
}

enum PurPOType {
  standard
  blanket
  framework
  contract
  service
  consignment
  drop_shipment
  emergency
  recurring
}

enum PurContractStatus {
  draft
  active
  expired
  terminated
  amended
}

enum PurReceiptStatus {
  expected
  partly_received
  fully_received
  reversed
  cancelled
}

enum PurInvoiceStatus {
  draft
  registered
  verified
  approved
  paid
  partially_paid
  cancelled
  on_hold
}

enum PurInvoiceMatchStatus {
  unmatched
  partially_matched
  fully_matched
  exception
}

enum PurImportStatus {
  declared
  customs_cleared
  goods_released
  duty_paid
  completed
}

enum PurApprovalStatus {
  pending
  approved
  rejected
  returned
  delegated
  escalated
}

// ─── Vendor ─────────────────────────────────────────────────────────────────────

model PurVendorGroup {
  id        String   @id @default(uuid())
  code      String   @unique @db.VarChar(20)
  name      String   @db.VarChar(255)
  nameEn    String?  @db.VarChar(255)
  isActive  Boolean  @default(true)
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  vendors PurVendor[]

  @@index([code])
  @@map("pur_vendor_groups")
}

model PurVendor {
  id              String          @id @default(uuid())
  groupId         String?
  group           PurVendorGroup? @relation(fields: [groupId], references: [id])
  code            String          @unique @db.VarChar(20)
  name            String          @db.VarChar(255)
  nameEn          String?         @db.VarChar(255)
  taxCode         String?         @db.VarChar(20)
  vendorType      PurVendorType   @default(company)
  category        String          @default("") @db.VarChar(50)
  status          PurVendorStatus @default(active)
  classification  String          @default("local") @db.VarChar(50)
  address         String?         @db.VarChar(500)
  ward            String?         @db.VarChar(100)
  district        String?         @db.VarChar(100)
  province        String?         @db.VarChar(100)
  country         String          @default("VN") @db.VarChar(2)
  postalCode      String?         @db.VarChar(20)
  phone           String?         @db.VarChar(50)
  email           String?         @db.VarChar(255)
  website         String?         @db.VarChar(255)
  paymentTermCode String?         @db.VarChar(20)
  currencyCode    String          @default("VND") @db.VarChar(3)
  isActive        Boolean         @default(true)
  version         Int             @default(1)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  contacts         PurVendorContact[]
  bankAccounts     PurVendorBankAccount[]
  taxInfos         PurVendorTaxInfo[]
  certificates     PurVendorCertificate[]
  evaluations      PurVendorEvaluation[]
  qualifications   PurVendorQualification[]
  purchaseOrders   PurPurchaseOrder[]
  goodsReceipts    PurGoodsReceipt[]
  supplierInvoices PurSupplierInvoice[]
  quotations       PurQuotation[]
  importDeclarations PurImportDeclaration[]

  @@index([code])
  @@index([taxCode])
  @@index([status])
  @@index([category])
  @@index([country])
  @@index([groupId])
  @@map("pur_vendors")
}

model PurVendorContact {
  id           String   @id @default(uuid())
  vendorId     String
  vendor       PurVendor @relation(fields: [vendorId], references: [id])
  fullName     String   @db.VarChar(255)
  email        String   @db.VarChar(255)
  phone        String   @db.VarChar(50)
  position     String?  @db.VarChar(255)
  isPrimary    Boolean  @default(false)
  isActive     Boolean  @default(true)
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  @@index([vendorId])
  @@map("pur_vendor_contacts")
}

model PurVendorBankAccount {
  id            String   @id @default(uuid())
  vendorId      String
  vendor        PurVendor @relation(fields: [vendorId], references: [id])
  bankName      String   @db.VarChar(255)
  branch        String?  @db.VarChar(255)
  accountNumber String   @db.VarChar(50)
  accountName   String   @db.VarChar(255)
  swiftCode     String?  @db.VarChar(11)
  currencyCode  String   @default("VND") @db.VarChar(3)
  isActive      Boolean  @default(true)
  isDefault     Boolean  @default(false)
  version       Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  @@index([vendorId])
  @@map("pur_vendor_bank_accounts")
}

model PurVendorTaxInfo {
  id        String   @id @default(uuid())
  vendorId  String
  vendor    PurVendor @relation(fields: [vendorId], references: [id])
  taxCode   String   @db.VarChar(20)
  taxAuthority String @db.VarChar(100)
  taxOffice String?  @db.VarChar(255)
  isDefault Boolean  @default(true)
  isActive  Boolean  @default(true)
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([vendorId])
  @@map("pur_vendor_tax_infos")
}

model PurVendorCertificate {
  id          String   @id @default(uuid())
  vendorId    String
  vendor      PurVendor @relation(fields: [vendorId], references: [id])
  type        String   @db.VarChar(100)
  number      String   @db.VarChar(100)
  issuedDate  DateTime
  expiryDate  DateTime?
  issuingBody String   @db.VarChar(255)
  notes       String?  @db.Text
  isActive    Boolean  @default(true)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([vendorId])
  @@map("pur_vendor_certificates")
}

model PurVendorEvaluation {
  id          String   @id @default(uuid())
  vendorId    String
  vendor      PurVendor @relation(fields: [vendorId], references: [id])
  evaluator   String   @db.VarChar(100)
  score       String   @db.VarChar(10)
  criteria    String   @db.Text
  comments    String?  @db.Text
  evaluatedAt DateTime
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([vendorId])
  @@map("pur_vendor_evaluations")
}

model PurVendorQualification {
  id          String   @id @default(uuid())
  vendorId    String
  vendor      PurVendor @relation(fields: [vendorId], references: [id])
  status      String   @default("under_review") @db.VarChar(50)
  qualifiedBy String   @db.VarChar(100)
  qualifiedAt DateTime
  expiresAt   DateTime?
  notes       String?  @db.Text
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([vendorId])
  @@index([status])
  @@map("pur_vendor_qualifications")
}

// ─── Purchase Requisition ────────────────────────────────────────────────────────

model PurPurchaseRequisition {
  id              String                  @id @default(uuid())
  prNumber        String                  @unique @db.VarChar(50)
  companyId       String                  @db.VarChar(50)
  branchId        String?                 @db.VarChar(50)
  departmentId    String?                 @db.VarChar(50)
  requesterId     String                  @db.VarChar(50)
  description     String?                 @db.Text
  status          PurRequisitionStatus    @default(draft)
  priority        String                  @default("medium") @db.VarChar(20)
  currencyCode    String                  @default("VND") @db.VarChar(3)
  totalEstimated  BigInt                  @default(0)
  notes           String?                 @db.Text
  submittedAt     DateTime?
  approvedAt      DateTime?
  approvedBy      String?                 @db.VarChar(100)
  cancelledAt     DateTime?
  cancelReason    String?                 @db.Text
  version         Int                     @default(1)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  deletedAt       DateTime?

  items PurRequisitionItem[]

  @@index([prNumber])
  @@index([companyId])
  @@index([status])
  @@index([requesterId])
  @@index([departmentId])
  @@map("pur_purchase_requisitions")
}

model PurRequisitionItem {
  id                String                  @id @default(uuid())
  requisitionId     String
  requisition       PurPurchaseRequisition  @relation(fields: [requisitionId], references: [id])
  lineNumber        Int
  itemId            String?                 @db.VarChar(50)
  itemCode          String                  @db.VarChar(50)
  itemName          String                  @db.VarChar(255)
  description       String?                 @db.Text
  quantity          Decimal                 @db.Decimal(18, 4)
  uom               String                  @db.VarChar(10)
  estimatedUnitPrice BigInt                 @default(0)
  estimatedTotal    BigInt                  @default(0)
  currencyCode      String                  @default("VND") @db.VarChar(3)
  requestedDate     DateTime?
  projectId         String?                 @db.VarChar(50)
  costCenterId      String?                 @db.VarChar(50)
  departmentId      String?                 @db.VarChar(50)
  branchId          String?                 @db.VarChar(50)
  warehouseId       String?                 @db.VarChar(50)
  budgetCheckStatus String?                 @db.VarChar(20)
  notes             String?                 @db.Text
  version           Int                     @default(1)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  deletedAt         DateTime?

  @@index([requisitionId])
  @@index([itemId])
  @@map("pur_requisition_items")
}

// ─── RFQ / Quotation ─────────────────────────────────────────────────────────────

model PurRFQ {
  id                String       @id @default(uuid())
  rfqNumber         String       @unique @db.VarChar(50)
  companyId         String       @db.VarChar(50)
  branchId          String?      @db.VarChar(50)
  title             String       @db.VarChar(255)
  description       String?      @db.Text
  status            PurRFQStatus @default(draft)
  currencyCode      String       @default("VND") @db.VarChar(3)
  totalEstimated    BigInt       @default(0)
  issueDate         DateTime?
  responseDeadline  DateTime?
  evaluatorId       String?      @db.VarChar(50)
  awardRecommendation String?    @db.VarChar(50)
  notes             String?      @db.Text
  version           Int          @default(1)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?

  items      PurRFQItem[]
  quotations PurQuotation[]

  @@index([rfqNumber])
  @@index([status])
  @@index([companyId])
  @@map("pur_rfqs")
}

model PurRFQItem {
  id                String   @id @default(uuid())
  rfqId             String
  rfq               PurRFQ   @relation(fields: [rfqId], references: [id])
  lineNumber        Int
  itemId            String?  @db.VarChar(50)
  itemCode          String   @db.VarChar(50)
  itemName          String   @db.VarChar(255)
  description       String?  @db.Text
  quantity          Decimal  @db.Decimal(18, 4)
  uom               String   @db.VarChar(10)
  expectedUnitPrice BigInt?
  currencyCode      String   @default("VND") @db.VarChar(3)
  requiredDate      DateTime?
  version           Int      @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  @@index([rfqId])
  @@map("pur_rfq_items")
}

model PurQuotation {
  id               String    @id @default(uuid())
  rfqId            String
  rfq              PurRFQ    @relation(fields: [rfqId], references: [id])
  vendorId         String
  vendor           PurVendor @relation(fields: [vendorId], references: [id])
  vendorName       String    @db.VarChar(255)
  quotationNumber  String    @unique @db.VarChar(50)
  status           String    @default("draft") @db.VarChar(20)
  currencyCode     String    @default("VND") @db.VarChar(3)
  totalAmount      BigInt    @default(0)
  validUntil       DateTime?
  notes            String?   @db.Text
  submittedAt      DateTime?
  acceptedAt       DateTime?
  rejectionReason  String?   @db.Text
  version          Int       @default(1)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  @@index([rfqId])
  @@index([vendorId])
  @@index([quotationNumber])
  @@map("pur_quotations")
}

// ─── Purchase Order ──────────────────────────────────────────────────────────────

model PurPurchaseOrder {
  id                  String       @id @default(uuid())
  poNumber            String       @unique @db.VarChar(50)
  companyId           String       @db.VarChar(50)
  branchId            String?      @db.VarChar(50)
  vendorId            String
  vendor              PurVendor    @relation(fields: [vendorId], references: [id])
  vendorName          String       @db.VarChar(255)
  vendorTaxCode       String?      @db.VarChar(20)
  poType              PurPOType    @default(standard)
  status              PurPOStatus  @default(draft)
  currencyCode        String       @default("VND") @db.VarChar(3)
  exchangeRate        Decimal      @default(1) @db.Decimal(18, 6)
  totalAmount         BigInt       @default(0)
  totalTax            BigInt       @default(0)
  grandTotal          BigInt       @default(0)
  description         String?      @db.Text
  notes               String?      @db.Text
  paymentTermCode     String?      @db.VarChar(20)
  incoterm            String?      @db.VarChar(10)
  freightTerm         String?      @db.VarChar(20)
  shipmentMethod      String?      @db.VarChar(100)
  requestedDate       DateTime?
  promisedDate        DateTime?
  approvedAt          DateTime?
  approvedBy          String?      @db.VarChar(100)
  sentAt              DateTime?
  confirmedAt         DateTime?
  confirmedBy         String?      @db.VarChar(100)
  closedAt            DateTime?
  cancelledAt         DateTime?
  cancelReason        String?      @db.Text
  holdReason          String?      @db.Text
  revisionNumber      Int          @default(0)
  sourceDocumentType  String?      @db.VarChar(50)
  sourceDocumentId    String?      @db.VarChar(50)
  version             Int          @default(1)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  deletedAt           DateTime?

  lines         PurPOLine[]
  goodsReceipts PurGoodsReceipt[]
  importDeclarations PurImportDeclaration[]

  @@index([poNumber])
  @@index([vendorId])
  @@index([status])
  @@index([companyId])
  @@index([poType])
  @@map("pur_purchase_orders")
}

model PurPOLine {
  id                String   @id @default(uuid())
  poId              String
  po                PurPurchaseOrder @relation(fields: [poId], references: [id])
  lineNumber        Int
  itemId            String?  @db.VarChar(50)
  itemCode          String   @db.VarChar(50)
  itemName          String   @db.VarChar(255)
  description       String?  @db.Text
  quantity          Decimal  @db.Decimal(18, 4)
  uom               String   @db.VarChar(10)
  unitPrice         BigInt   @default(0)
  totalPrice        BigInt   @default(0)
  currencyCode      String   @default("VND") @db.VarChar(3)
  taxCode           String?  @db.VarChar(20)
  taxRate           Decimal  @default(0) @db.Decimal(5, 2)
  receivedQuantity  Decimal  @default(0) @db.Decimal(18, 4)
  invoicedQuantity  Decimal  @default(0) @db.Decimal(18, 4)
  expectedDate      DateTime?
  promiseDate       DateTime?
  projectId         String?  @db.VarChar(50)
  costCenterId      String?  @db.VarChar(50)
  departmentId      String?  @db.VarChar(50)
  branchId          String?  @db.VarChar(50)
  warehouseId       String?  @db.VarChar(50)
  receiptStatus     String   @default("pending") @db.VarChar(20)
  notes             String?  @db.Text
  version           Int      @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  @@index([poId])
  @@index([itemId])
  @@map("pur_po_lines")
}

// ─── Purchase Contract ───────────────────────────────────────────────────────────

model PurPurchaseContract {
  id              String            @id @default(uuid())
  contractNumber  String            @unique @db.VarChar(50)
  companyId       String            @db.VarChar(50)
  vendorId        String            @db.VarChar(50)
  vendorName      String            @db.VarChar(255)
  contractType    String            @default("fixed_price") @db.VarChar(50)
  status          PurContractStatus @default(draft)
  title           String            @db.VarChar(255)
  description     String?           @db.Text
  currencyCode    String            @default("VND") @db.VarChar(3)
  totalValue      BigInt            @default(0)
  amountSpent     BigInt            @default(0)
  amountRemaining BigInt            @default(0)
  startDate       DateTime
  endDate         DateTime
  renewalDate     DateTime?
  maxOrderQty     Decimal?          @db.Decimal(18, 4)
  orderedQty      Decimal           @default(0) @db.Decimal(18, 4)
  paymentTermCode String?           @db.VarChar(20)
  incoterm        String?           @db.VarChar(10)
  notes           String?           @db.Text
  amendmentNumber Int               @default(0)
  version         Int               @default(1)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  @@index([contractNumber])
  @@index([vendorId])
  @@index([status])
  @@index([companyId])
  @@map("pur_purchase_contracts")
}

// ─── Goods Receipt ───────────────────────────────────────────────────────────────

model PurGoodsReceipt {
  id            String          @id @default(uuid())
  receiptNumber String          @unique @db.VarChar(50)
  companyId     String          @db.VarChar(50)
  branchId      String?         @db.VarChar(50)
  warehouseId   String?         @db.VarChar(50)
  vendorId      String
  vendor        PurVendor       @relation(fields: [vendorId], references: [id])
  vendorName    String          @db.VarChar(255)
  poId          String
  po            PurPurchaseOrder @relation(fields: [poId], references: [id])
  poNumber      String          @db.VarChar(50)
  receiptType   String          @default("standard") @db.VarChar(20)
  status        PurReceiptStatus @default(fully_received)
  currencyCode  String          @default("VND") @db.VarChar(3)
  totalAmount   BigInt          @default(0)
  notes         String?         @db.Text
  receiptDate   DateTime
  receivedBy    String          @db.VarChar(100)
  reversedAt    DateTime?
  reverseReason String?         @db.Text
  version       Int             @default(1)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  lines PurReceiptLine[]

  @@index([receiptNumber])
  @@index([poId])
  @@index([vendorId])
  @@index([warehouseId])
  @@map("pur_goods_receipts")
}

model PurReceiptLine {
  id                String   @id @default(uuid())
  receiptId         String
  receipt           PurGoodsReceipt @relation(fields: [receiptId], references: [id])
  poId              String   @db.VarChar(50)
  poLineId          String   @db.VarChar(50)
  lineNumber        Int
  itemId            String?  @db.VarChar(50)
  itemCode          String   @db.VarChar(50)
  itemName          String   @db.VarChar(255)
  quantityOrdered   Decimal  @default(0) @db.Decimal(18, 4)
  quantityReceived  Decimal  @db.Decimal(18, 4)
  quantityAccepted  Decimal  @default(0) @db.Decimal(18, 4)
  quantityRejected  Decimal  @default(0) @db.Decimal(18, 4)
  uom               String   @db.VarChar(10)
  unitPrice         BigInt   @default(0)
  totalPrice        BigInt   @default(0)
  currencyCode      String   @default("VND") @db.VarChar(3)
  warehouseId       String?  @db.VarChar(50)
  locationId        String?  @db.VarChar(50)
  batchNumber       String?  @db.VarChar(100)
  serialNumber      String?  @db.VarChar(100)
  expiryDate        DateTime?
  inspectionStatus  String   @default("pending") @db.VarChar(20)
  inspectionNotes   String?  @db.Text
  notes             String?  @db.Text
  version           Int      @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  @@index([receiptId])
  @@index([poLineId])
  @@index([itemId])
  @@map("pur_receipt_lines")
}

// ─── Supplier Invoice ────────────────────────────────────────────────────────────

model PurSupplierInvoice {
  id                String            @id @default(uuid())
  invoiceNumber     String            @unique @db.VarChar(100)
  invoiceDate       DateTime
  companyId         String            @db.VarChar(50)
  branchId          String?           @db.VarChar(50)
  vendorId          String
  vendor            PurVendor         @relation(fields: [vendorId], references: [id])
  vendorName        String            @db.VarChar(255)
  vendorTaxCode     String?           @db.VarChar(20)
  poId              String?           @db.VarChar(50)
  poNumber          String?           @db.VarChar(50)
  status            PurInvoiceStatus  @default(draft)
  matchStatus       PurInvoiceMatchStatus @default(unmatched)
  matchingRule      String            @default("three_way") @db.VarChar(20)
  currencyCode      String            @default("VND") @db.VarChar(3)
  exchangeRate      Decimal           @default(1) @db.Decimal(18, 6)
  totalAmount       BigInt            @default(0)
  totalTax          BigInt            @default(0)
  grandTotal        BigInt            @default(0)
  amountPaid        BigInt            @default(0)
  amountDue         BigInt            @default(0)
  paymentStatus     String            @default("pending") @db.VarChar(20)
  paymentTermCode   String?           @db.VarChar(20)
  dueDate           DateTime?
  description       String?           @db.Text
  notes             String?           @db.Text
  holdReason        String?           @db.Text
  approvedAt        DateTime?
  approvedBy        String?           @db.VarChar(100)
  paidAt            DateTime?
  cancelledAt       DateTime?
  cancelReason      String?           @db.Text
  version           Int               @default(1)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?

  lines PurInvoiceLine[]

  @@index([invoiceNumber])
  @@index([vendorId])
  @@index([status])
  @@index([poId])
  @@index([companyId])
  @@map("pur_supplier_invoices")
}

model PurInvoiceLine {
  id                String   @id @default(uuid())
  invoiceId         String
  invoice           PurSupplierInvoice @relation(fields: [invoiceId], references: [id])
  lineNumber        Int
  poId              String?  @db.VarChar(50)
  poLineId          String?  @db.VarChar(50)
  itemId            String?  @db.VarChar(50)
  itemCode          String   @db.VarChar(50)
  itemName          String   @db.VarChar(255)
  quantity          Decimal  @db.Decimal(18, 4)
  uom               String   @db.VarChar(10)
  unitPrice         BigInt   @default(0)
  totalPrice        BigInt   @default(0)
  taxCode           String?  @db.VarChar(20)
  taxRate           Decimal  @default(0) @db.Decimal(5, 2)
  taxAmount         BigInt   @default(0)
  currencyCode      String   @default("VND") @db.VarChar(3)
  matchedQuantity   Decimal  @default(0) @db.Decimal(18, 4)
  matchedAmount     BigInt   @default(0)
  matchStatus       String   @default("unmatched") @db.VarChar(20)
  projectId         String?  @db.VarChar(50)
  costCenterId      String?  @db.VarChar(50)
  notes             String?  @db.Text
  version           Int      @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  @@index([invoiceId])
  @@index([poLineId])
  @@map("pur_invoice_lines")
}

// ─── Import / Foreign Trade ──────────────────────────────────────────────────────

model PurImportDeclaration {
  id                  String          @id @default(uuid())
  declarationNumber   String          @unique @db.VarChar(50)
  companyId           String          @db.VarChar(50)
  branchId            String?         @db.VarChar(50)
  poId                String
  po                  PurPurchaseOrder @relation(fields: [poId], references: [id])
  poNumber            String          @db.VarChar(50)
  vendorId            String
  vendor              PurVendor       @relation(fields: [vendorId], references: [id])
  vendorName          String          @db.VarChar(255)
  shipmentId          String?         @db.VarChar(50)
  status              PurImportStatus @default(declared)
  incoterm            String          @default("CIF") @db.VarChar(10)
  freightTerm         String          @default("prepaid") @db.VarChar(20)
  portOfLoading       String?         @db.VarChar(255)
  portOfDischarge     String?         @db.VarChar(255)
  currencyCode        String          @default("VND") @db.VarChar(3)
  exchangeRate        Decimal         @default(1) @db.Decimal(18, 6)
  totalCifValue       BigInt          @default(0)
  totalDutyAmount     BigInt          @default(0)
  totalTaxAmount      BigInt          @default(0)
  totalLandedCost     BigInt          @default(0)
  customsClearanceDate DateTime?
  notes               String?         @db.Text
  version             Int             @default(1)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?

  landedCosts PurLandedCost[]

  @@index([declarationNumber])
  @@index([poId])
  @@index([vendorId])
  @@map("pur_import_declarations")
}

model PurLandedCost {
  id                  String   @id @default(uuid())
  importDeclarationId String
  importDeclaration   PurImportDeclaration @relation(fields: [importDeclarationId], references: [id])
  costType            String   @db.VarChar(50)
  description         String   @db.VarChar(255)
  amount              BigInt   @default(0)
  currencyCode        String   @default("VND") @db.VarChar(3)
  allocationBasis     String   @default("value") @db.VarChar(20)
  postedToInventory   Boolean  @default(false)
  version             Int      @default(1)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  deletedAt           DateTime?

  @@index([importDeclarationId])
  @@map("pur_landed_costs")
}

// ─── Approval Workflow ────────────────────────────────────────────────────────────

model PurApprovalRequest {
  id            String             @id @default(uuid())
  companyId     String             @db.VarChar(50)
  entityType    String             @db.VarChar(50)
  entityId      String             @db.VarChar(50)
  entityNumber  String             @db.VarChar(50)
  status        PurApprovalStatus  @default(pending)
  requestedBy   String             @db.VarChar(100)
  requestedAt   DateTime
  approvedBy    String?            @db.VarChar(100)
  approvedAt    DateTime?
  rejectedBy    String?            @db.VarChar(100)
  rejectedAt    DateTime?
  rejectReason  String?            @db.Text
  escalatedTo   String?            @db.VarChar(100)
  escalatedAt   DateTime?
  notes         String?            @db.Text
  version       Int                @default(1)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?

  @@index([entityType, entityId])
  @@index([status])
  @@index([requestedBy])
  @@map("pur_approval_requests")
}
