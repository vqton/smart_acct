  departmentId     String?  @db.VarChar(36)
  projectId        String?  @db.VarChar(36)
  productId        String?  @db.VarChar(36)
  description      String?  @db.VarChar(255)
  forecastAmount   Decimal  @default(0) @db.Decimal(19,4)
