// ─── Budget Plan ───────────────────────────────────────────────────────────────

model BgtBudgetPlan {
  id                String   @id @default(uuid())
  code              String   @unique @db.VarChar(50)
  name              String   @db.VarChar(255)
  description       String?  @db.Text
  budgetType        BgtBudgetType @default(annual)
  status            BgtBudgetStatus @default(draft)
  fiscalYearId      String   @db.VarChar(36)
  currencyCode      String   @default("VND") @db.VarChar(3)
  totalPlannedAmount  Decimal @default(0) @db.Decimal(19,4)
  totalApprovedAmount Decimal @default(0) @db.Decimal(19,4)
  totalRemainingAmount Decimal @default(0) @db.Decimal(19,4)
  totalReservedAmount  Decimal @default(0) @db.Decimal(19,4)
  totalConsumedAmount  Decimal @default(0) @db.Decimal(19,4)
  startDate         DateTime?
  endDate           DateTime?
  notes             String?  @db.Text
  isTemplate        Boolean  @default(false)
  parentId          String?  @db.VarChar(36)
  createdById       String?  @db.VarChar(36)
  approvedById      String?  @db.VarChar(36)
  approvedAt        DateTime?
  publishedAt       DateTime?
  version           Int      @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  parent    BgtBudgetPlan?  @relation("BudgetPlanHierarchy", fields: [parentId], references: [id])
  children  BgtBudgetPlan[] @relation("BudgetPlanHierarchy")

  versions     BgtBudgetVersion[]
  details      BgtBudgetDetail[]
  transfersOut BgtBudgetTransfer[]  @relation("TransferSource")
  transfersIn  BgtBudgetTransfer[]  @relation("TransferTarget")
  reservations BgtBudgetReservation[]
  snapshots    BgtBudgetSnapshot[]
  scenarios    BgtBudgetScenario[]
  forecastHeaders BgtForecastHeader[]
  budgetJournals  BgtBudgetJournal[]
  auditLogs       BgtBudgetAuditLog[]

  @@index([code])
  @@index([fiscalYearId])
  @@index([status])
  @@index([budgetType])
  @@index([parentId])
  @@map("bgt_budget_plans")
}

// ─── Budget Version ────────────────────────────────────────────────────────────

model BgtBudgetVersion {
  id            String   @id @default(uuid())
  budgetPlanId  String
  budgetPlan    BgtBudgetPlan @relation(fields: [budgetPlanId], references: [id])
  versionNumber Int
  label         String   @db.VarChar(255)
  description   String?  @db.Text
  status        BgtBudgetVersionStatus @default(working)
  totalAmount   Decimal  @default(0) @db.Decimal(19,4)
  isCurrent     Boolean  @default(false)
  isApproved    Boolean  @default(false)
  frozenAt      DateTime?
  approvedById  String?  @db.VarChar(36)
  approvedAt    DateTime?
  createdById   String?  @db.VarChar(36)
  sourceVersionId String? @db.VarChar(36)
  notes         String?  @db.Text
  version       Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  details BgtBudgetDetail[]

  @@unique([budgetPlanId, versionNumber])
  @@index([budgetPlanId])
  @@index([status])
  @@map("bgt_budget_versions")
}

