}

// ─── Budget Control ────────────────────────────────────────────────────────────

model BgtBudgetControl {
  id              String   @id @default(uuid())
  budgetDetailId  String
  budgetDetail    BgtBudgetDetail @relation(fields: [budgetDetailId], references: [id])
  controlLevel    BgtBudgetControlLevel @default(none)
  controlAction   BgtBudgetControlAction @default(block)
  toleranceAmount Decimal  @default(0) @db.Decimal(19,4)
  tolerancePct    Decimal  @default(0) @db.Decimal(7,2)
  effectiveFrom   DateTime?
  effectiveTo     DateTime?
  isActive        Boolean  @default(true)
  checkedAt       DateTime?
  checkedById     String?  @db.VarChar(36)
  checkResult     String?  @db.VarChar(20)
  checkMessage    String?  @db.Text
  version         Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reservationLines BgtBudgetReservationLine[]

  @@index([budgetDetailId])
  @@index([controlLevel])
  @@map("bgt_budget_controls")
}

// ─── Budget Reservation (Commitment/Encumbrance) ───────────────────────────────

model BgtBudgetReservation {
  id              String   @id @default(uuid())
  budgetPlanId    String
  budgetPlan      BgtBudgetPlan @relation(fields: [budgetPlanId], references: [id])
  reservationNumber String @unique @db.VarChar(50)
  commitmentType  BgtCommitmentType @default(reservation)
  status          BgtReservationStatus @default(draft)
  sourceDocumentType String? @db.VarChar(50)
  sourceDocumentId   String? @db.VarChar(36)
  sourceLineId       String? @db.VarChar(36)
  description     String?  @db.Text
  totalAmount     Decimal  @default(0) @db.Decimal(19,4)
  consumedAmount  Decimal  @default(0) @db.Decimal(19,4)
  releasedAmount  Decimal  @default(0) @db.Decimal(19,4)
  remainingAmount Decimal  @default(0) @db.Decimal(19,4)
  currencyCode    String   @default("VND") @db.VarChar(3)
  reservedAt      DateTime?
  releasedAt      DateTime?
  expiresAt       DateTime?
  cancelledAt     DateTime?
  cancelReason    String?  @db.Text
  createdById     String?  @db.VarChar(36)
  version         Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reservationLines BgtBudgetReservationLine[]

  @@index([budgetPlanId])
  @@index([reservationNumber])
  @@index([status])
  @@index([commitmentType])
  @@index([sourceDocumentType, sourceDocumentId])
  @@map("bgt_budget_reservations")
}

// ─── Budget Reservation Line ───────────────────────────────────────────────────

model BgtBudgetReservationLine {
  id              String   @id @default(uuid())
  reservationId   String
  reservation     BgtBudgetReservation @relation(fields: [reservationId], references: [id])
  budgetDetailId  String
  budgetDetail    BgtBudgetDetail @relation(fields: [budgetDetailId], references: [id])
  budgetControlId String?
  budgetControl   BgtBudgetControl? @relation(fields: [budgetControlId], references: [id])
  lineNumber      Int
  amount          Decimal  @default(0) @db.Decimal(19,4)
  consumedAmount  Decimal  @default(0) @db.Decimal(19,4)
  releasedAmount  Decimal  @default(0) @db.Decimal(19,4)
  remainingAmount Decimal  @default(0) @db.Decimal(19,4)
  glAccountId     String?  @db.VarChar(36)
  costCenterId    String?  @db.VarChar(36)
  departmentId    String?  @db.VarChar(36)
  projectId       String?  @db.VarChar(36)
  description     String?  @db.VarChar(255)
  periodNumber    Int      @default(1)
  isActive        Boolean  @default(true)
  version         Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([reservationId])
  @@index([budgetDetailId])
  @@map("bgt_budget_reservation_lines")
}

// ─── Budget Transfer ───────────────────────────────────────────────────────────

model BgtBudgetTransfer {
  id              String   @id @default(uuid())
  transferNumber  String   @unique @db.VarChar(50)
  sourceBudgetPlanId String
  sourceBudgetPlan   BgtBudgetPlan @relation("TransferSource", fields: [sourceBudgetPlanId], references: [id])
  targetBudgetPlanId String
  targetBudgetPlan   BgtBudgetPlan @relation("TransferTarget", fields: [targetBudgetPlanId], references: [id])
  description     String?  @db.Text
  totalAmount     Decimal  @default(0) @db.Decimal(19,4)
  status          String   @default("draft") @db.VarChar(20)
  effectiveDate   DateTime?
  approvedById    String?  @db.VarChar(36)
  approvedAt      DateTime?
  glJournalBatchId String? @db.VarChar(36)
  postedToGL      Boolean  @default(false)
  postedAt        DateTime?
  notes           String?  @db.Text
  createdById     String?  @db.VarChar(36)
  version         Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transferLines BgtBudgetTransferLine[]

  @@index([transferNumber])
  @@index([sourceBudgetPlanId])
  @@index([targetBudgetPlanId])
  @@index([status])
  @@map("bgt_budget_transfers")
}

// ─── Budget Transfer Line ──────────────────────────────────────────────────────

model BgtBudgetTransferLine {
  id              String   @id @default(uuid())
