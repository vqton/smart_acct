  description     String?  @db.VarChar(255)
  periodNumber    Int      @default(1)
  version         Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([transferId])
  @@map("bgt_budget_transfer_lines")
}

// ─── Approval Workflow ─────────────────────────────────────────────────────────

model BgtApprovalRequest {
  id              String   @id @default(uuid())
  budgetPlanId    String   @db.VarChar(36)
  requestNumber   String   @unique @db.VarChar(50)
  description     String?  @db.Text
  status          BgtApprovalStatus @default(pending)
  totalAmount     Decimal  @default(0) @db.Decimal(19,4)
  requestedById   String?  @db.VarChar(36)
  requestedAt     DateTime @default(now())
  completedAt     DateTime?
  notes           String?  @db.Text
  version         Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  approvalSteps BgtApprovalStep[]

  @@index([budgetPlanId])
  @@index([requestNumber])
  @@index([status])
  @@map("bgt_approval_requests")
}

model BgtApprovalStep {
  id              String   @id @default(uuid())
  approvalRequestId String
  approvalRequest BgtApprovalRequest @relation(fields: [approvalRequestId], references: [id])
  stepOrder       Int
  approverId      String   @db.VarChar(36)
  delegateId      String?  @db.VarChar(36)
  status          BgtApprovalStatus @default(pending)
  decision        BgtApprovalDecision?
  comments        String?  @db.Text
  decidedAt       DateTime?
  slaDeadline     DateTime?
  reminderSentAt  DateTime?
  escalationAt    DateTime?
  version         Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([approvalRequestId, stepOrder])
  @@index([approvalRequestId])
  @@index([approverId])
  @@index([status])
  @@map("bgt_approval_steps")
}

// ─── Budget Snapshot ───────────────────────────────────────────────────────────

model BgtBudgetSnapshot {
