// ─── Budget Period Balance ─────────────────────────────────────────────────────

model BgtBudgetPeriodBalance {
  id             String   @id @default(uuid())
  budgetDetailId String
  budgetDetail   BgtBudgetDetail @relation(fields: [budgetDetailId], references: [id])
  periodId       String   @db.VarChar(36)
  periodNumber   Int
  budgetAmount   Decimal  @default(0) @db.Decimal(19,4)
  actualAmount   Decimal  @default(0) @db.Decimal(19,4)
  committedAmount Decimal @default(0) @db.Decimal(19,4)
  encumberedAmount Decimal @default(0) @db.Decimal(19,4)
  reservedAmount Decimal  @default(0) @db.Decimal(19,4)
  consumedAmount Decimal  @default(0) @db.Decimal(19,4)
  varianceAmount Decimal  @default(0) @db.Decimal(19,4)
  variancePct    Decimal  @default(0) @db.Decimal(7,2)
  currencyCode   String   @default("VND") @db.VarChar(3)
  version        Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([budgetDetailId, periodId])
  @@index([budgetDetailId])
  @@index([periodId])
  @@map("bgt_budget_period_balances")
}

// ─── Budget Scenario ───────────────────────────────────────────────────────────

model BgtBudgetScenario {
  id             String   @id @default(uuid())
  budgetPlanId   String
  budgetPlan     BgtBudgetPlan @relation(fields: [budgetPlanId], references: [id])
  code           String   @db.VarChar(50)
  name           String   @db.VarChar(255)
  scenarioType   BgtBudgetScenarioType @default(base)
  description    String?  @db.Text
  assumptions    String?  @db.Text
  isBase         Boolean  @default(false)
  confidencePct  Decimal? @default(0) @db.Decimal(5,2)
  weightPct      Decimal? @default(0) @db.Decimal(5,2)
  createdById    String?  @db.VarChar(36)
  version        Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  forecastHeaders BgtForecastHeader[]

  @@unique([budgetPlanId, code])
  @@index([budgetPlanId])
  @@map("bgt_budget_scenarios")
}

// ─── Forecast Header ───────────────────────────────────────────────────────────

model BgtForecastHeader {
  id             String   @id @default(uuid())
  budgetPlanId   String
  budgetPlan     BgtBudgetPlan @relation(fields: [budgetPlanId], references: [id])
  scenarioId     String?
  scenario       BgtBudgetScenario? @relation(fields: [scenarioId], references: [id])
  forecastNumber String   @unique @db.VarChar(50)
  forecastMethod BgtForecastMethod @default(manual)
  status         BgtForecastStatus @default(draft)
  description    String?  @db.Text
  forecastPeriods Int     @default(12)
  periodType     BgtPeriodType @default(monthly)
  startDate      DateTime?
  endDate        DateTime?
  totalForecastAmount Decimal @default(0) @db.Decimal(19,4)
  confidencePct  Decimal? @db.Decimal(5,2)
  notes          String?  @db.Text
  createdById    String?  @db.VarChar(36)
  approvedById   String?  @db.VarChar(36)
  approvedAt     DateTime?
  version        Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  forecastLines BgtForecastLine[]
  forecastDrivers BgtForecastDriver[]

  @@index([budgetPlanId])
  @@index([forecastNumber])
  @@index([status])
  @@index([forecastMethod])
  @@map("bgt_forecast_headers")
}

// ─── Forecast Line ─────────────────────────────────────────────────────────────

model BgtForecastLine {
  id               String   @id @default(uuid())
