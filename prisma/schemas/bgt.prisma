}

// ─── Budget Allocation Rule ────────────────────────────────────────────────────

model BgtAllocationRule {
  id              String   @id @default(uuid())
  code            String   @unique @db.VarChar(50)
  name            String   @db.VarChar(255)
  description     String?  @db.Text
  allocationMethod BgtAllocationMethod @default(percentage)
  status          BgtAllocationStatus @default(draft)
  sourceBudgetPlanId String? @db.VarChar(36)
  targetBudgetPlanId String? @db.VarChar(36)
  sourceDimensionType String? @db.VarChar(50)
  sourceDimensionId   String? @db.VarChar(36)
  targetDimensionType String? @db.VarChar(50)
  targetDimensionId   String? @db.VarChar(36)
  totalAmount     Decimal  @default(0) @db.Decimal(19,4)
  allocatedAmount Decimal  @default(0) @db.Decimal(19,4)
  remainingAmount Decimal  @default(0) @db.Decimal(19,4)
  fiscalYearId    String?  @db.VarChar(36)
  periodType      BgtPeriodType @default(monthly)
  isRecurring     Boolean  @default(false)
  recurrenceInterval String? @db.VarChar(50)
  lastRunAt       DateTime?
  nextRunAt       DateTime?
  notes           String?  @db.Text
  createdById     String?  @db.VarChar(36)
  approvedById    String?  @db.VarChar(36)
  version         Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  ruleLines     BgtAllocationRuleLine[]
  ruleResults   BgtAllocationResult[]

  @@index([code])
  @@index([status])
  @@index([allocationMethod])
  @@map("bgt_allocation_rules")
}

// ─── Allocation Rule Line ──────────────────────────────────────────────────────

model BgtAllocationRuleLine {
  id              String   @id @default(uuid())
  ruleId          String
  rule            BgtAllocationRule @relation(fields: [ruleId], references: [id])
  lineNumber      Int
  sourceGlAccountId  String? @db.VarChar(36)
  targetGlAccountId  String? @db.VarChar(36)
  sourceCostCenterId String? @db.VarChar(36)
  targetCostCenterId String? @db.VarChar(36)
  sourceDepartmentId String? @db.VarChar(36)
  targetDepartmentId String? @db.VarChar(36)
  sourceProjectId    String? @db.VarChar(36)
  targetProjectId    String? @db.VarChar(36)
  allocationPct   Decimal  @default(0) @db.Decimal(7,4)
  allocationAmount Decimal @default(0) @db.Decimal(19,4)
  driverId        String?  @db.VarChar(36)
  driverValue     Decimal? @db.Decimal(19,4)
  description     String?  @db.VarChar(255)
  isActive        Boolean  @default(true)
  version         Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ruleId])
  @@map("bgt_allocation_rule_lines")
}

// ─── Allocation Result ─────────────────────────────────────────────────────────

model BgtAllocationResult {
  id              String   @id @default(uuid())
  ruleId          String
  rule            BgtAllocationRule @relation(fields: [ruleId], references: [id])
  runNumber       String   @db.VarChar(50)
  periodId        String?  @db.VarChar(36)
  sourceAmount    Decimal  @default(0) @db.Decimal(19,4)
  allocatedAmount Decimal  @default(0) @db.Decimal(19,4)
  sourceAccountId  String? @db.VarChar(36)
  targetAccountId  String? @db.VarChar(36)
  sourceCostCenterId String? @db.VarChar(36)
  targetCostCenterId String? @db.VarChar(36)
  sourceDepartmentId String? @db.VarChar(36)
  targetDepartmentId String? @db.VarChar(36)
  sourceProjectId    String? @db.VarChar(36)
  targetProjectId    String? @db.VarChar(36)
  glJournalBatchId   String? @db.VarChar(36)
  postedToGL         Boolean @default(false)
  postedAt           DateTime?
  version         Int      @default(1)
  createdAt       DateTime @default(now())
