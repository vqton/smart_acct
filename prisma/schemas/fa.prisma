// ─── Master Data ─────────────────────────────────────────────────────────────────

model FaAssetGroup {
  id          String     @id @default(uuid())
  code        String     @unique @db.VarChar(20)
  name        String     @db.VarChar(255)
  nameEn      String?    @db.VarChar(255)
  description String?    @db.Text
  parentId    String?
  parent      FaAssetGroup?  @relation("AssetGroupHierarchy", fields: [parentId], references: [id])
  children    FaAssetGroup[] @relation("AssetGroupHierarchy")
  assetType   FaAssetType
  category    FaAssetCategory?
  usefulLifeMin Int?
  usefulLifeMax Int?
  depreciationMethod FaDepreciationMethod?
  residualValueRate Decimal? @db.Decimal(5, 2)
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  version     Int        @default(1)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  classes     FaAssetClass[]
  assets      FaAsset[]

  @@index([code])
  @@index([parentId])
  @@index([assetType])
  @@index([isActive])
  @@map("fa_asset_groups")
}

model FaAssetClass {
  id          String     @id @default(uuid())
  code        String     @unique @db.VarChar(20)
  name        String     @db.VarChar(255)
  nameEn      String?    @db.VarChar(255)
  groupId     String?
  group       FaAssetGroup? @relation(fields: [groupId], references: [id])
  assetType   FaAssetType
  description String?    @db.Text
  usefulLifeYears  Int?
  depreciationMethod FaDepreciationMethod?
  residualValueRate Decimal? @db.Decimal(5, 2)
  glAssetAccountId String? @db.VarChar(36)
  glDepreciationAccountId String? @db.VarChar(36)
  glAccumulatedDepreciationId String? @db.VarChar(36)
  glExpenseAccountId String? @db.VarChar(36)
  glDisposalAccountId String? @db.VarChar(36)
  isActive    Boolean    @default(true)
  version     Int        @default(1)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  categories  FaAssetCategory[]
  assets      FaAsset[]

  @@index([code])
  @@index([groupId])
  @@index([assetType])
  @@map("fa_asset_classes")
}

model FaAssetCategory {
  id          String       @id @default(uuid())
  code        String       @unique @db.VarChar(20)
  name        String       @db.VarChar(255)
  nameEn      String?      @db.VarChar(255)
  classId     String?
  class       FaAssetClass? @relation(fields: [classId], references: [id])
  description String?      @db.Text
  isActive    Boolean      @default(true)
  version     Int          @default(1)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  assets      FaAsset[]

  @@index([code])
  @@index([classId])
  @@map("fa_asset_categories")
}

// ─── Asset Master ─────────────────────────────────────────────────────────────────

model FaAsset {
  id                  String         @id @default(uuid())
  companyId           String
  branchId            String?
  assetCode           String         @unique @db.VarChar(50)
  assetName           String         @db.VarChar(255)
  assetNameEn         String?        @db.VarChar(255)
  description         String?        @db.Text
  assetType           FaAssetType
  assetStatus         FaAssetStatus  @default(draft)
  groupId             String?
  group               FaAssetGroup?  @relation(fields: [groupId], references: [id])
  classId             String?
  class               FaAssetClass?  @relation(fields: [classId], references: [id])
  categoryId          String?
  category            FaAssetCategory? @relation(fields: [categoryId], references: [id])
  parentId            String?
  parent              FaAsset?       @relation("AssetHierarchy", fields: [parentId], references: [id])
  children            FaAsset[]      @relation("AssetHierarchy")
  rootAssetId         String?
  isComponent         Boolean        @default(false)
  isLeased            Boolean        @default(false)
  isCip               Boolean        @default(false)
  isInvestmentProperty Boolean       @default(false)

  // Acquisition
  acquisitionType     FaAcquisitionType?
  acquisitionDate     DateTime?
  capitalizationDate  DateTime?
  inUseDate           DateTime?
  disposalDate        DateTime?
  retirementDate      DateTime?

  // Financial
  originalCost        BigInt         @default(0)
  accumulatedDepreciation BigInt     @default(0)
  netBookValue        BigInt         @default(0)
  residualValue       BigInt         @default(0)
  revaluationAmount   BigInt         @default(0)
  impairmentAmount    BigInt         @default(0)
  revaluationReserve  BigInt         @default(0)
  currencyCode        String         @default("VND") @db.VarChar(3)
  exchangeRate        Decimal        @default(1.0) @db.Decimal(19, 6)

  // Depreciation
  depreciationMethod  FaDepreciationMethod
  usefulLifeYears     Int            @default(0)
  usefulLifeMonths    Int            @default(0)
  usefulLifeUnits     Decimal?       @db.Decimal(19, 4)
  unitsProduced       Decimal?       @db.Decimal(19, 4)
  depreciationRate    Decimal?       @db.Decimal(7, 4)
  depreciationStartDate DateTime?
  depreciationEndDate   DateTime?
  isFullyDepreciated  Boolean        @default(false)
  isSuspended         Boolean        @default(false)
  suspensionStartDate DateTime?
  suspensionEndDate   DateTime?

  // Dimensions
  costCenterId        String?        @db.VarChar(36)
  profitCenterId      String?        @db.VarChar(36)
  departmentId        String?        @db.VarChar(36)
  projectId           String?        @db.VarChar(36)
  businessUnitId      String?        @db.VarChar(36)
  locationId          String?        @db.VarChar(36)
  custodianId         String?        @db.VarChar(36)
  custodianName       String?        @db.VarChar(255)
  ownerId             String?        @db.VarChar(36)

  // Physical
  serialNumber        String?        @unique @db.VarChar(100)
  modelNumber         String?        @db.VarChar(100)
  manufacturer        String?        @db.VarChar(255)
  manufacturerYear    Int?
  manufactureCountry  String?        @db.VarChar(100)
  supplierId          String?        @db.VarChar(36)
  supplierName        String?        @db.VarChar(255)
  warrantyExpiryDate  DateTime?
  insurancePolicyNumber String?      @db.VarChar(100)
  insuranceExpiryDate DateTime?
  insuredValue        BigInt?        @default(0)

  // Location
  address             String?        @db.Text
  ward                String?        @db.VarChar(100)
  district            String?        @db.VarChar(100)
  province            String?        @db.VarChar(100)
  country             String?        @default("VN") @db.VarChar(2)
  gpsCoordinates      String?        @db.VarChar(50)
  building            String?        @db.VarChar(100)
  floor               String?        @db.VarChar(50)
  room                String?        @db.VarChar(100)

  // Tax
  taxCode             String?        @db.VarChar(50)
  taxAuthority        String?        @db.VarChar(100)
  vatRate             Decimal?       @db.Decimal(5, 2)
  importDutyPaid      BigInt?        @default(0)
  nonRefundableTax    BigInt?        @default(0)

  // CIP Reference
  cipProjectId        String?        @db.VarChar(36)
  poNumber            String?        @db.VarChar(50)
  invoiceNumber       String?        @db.VarChar(50)
  contractNumber      String?        @db.VarChar(50)

  // Workflow
  approvalStatus      String?        @db.VarChar(20)
  approvedById        String?        @db.VarChar(36)
  approvedAt          DateTime?
  version             Int            @default(1)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  deletedAt           DateTime?

  // Relations
  components          FaAsset[]      @relation("AssetHierarchy")
  deprAreas           FaAssetDepreciation[]
  deprEntries         FaDepreciationEntry[]
  revaluations        FaRevaluation[]
  impairments         FaImpairment[]
  disposals           FaDisposal[]
  transfers           FaTransfer[]
  maintenanceRecords  FaMaintenanceRecord[]
  tags                FaAssetTag[]
  verifications       FaVerificationLine[]
  histories           FaAssetHistory[]
  snapshots           FaSnapshot[]
  glMappings          FaGlMapping[]

  @@index([companyId])
  @@index([branchId])
  @@index([assetCode])
  @@index([assetType])
  @@index([assetStatus])
  @@index([groupId])
  @@index([classId])
  @@index([categoryId])
  @@index([parentId])
  @@index([costCenterId])
  @@index([profitCenterId])
  @@index([departmentId])
  @@index([projectId])
  @@index([custodianId])
  @@index([locationId])
  @@index([serialNumber])
  @@index([acquisitionDate])
  @@index([capitalizationDate])
  @@index([isFullyDepreciated])
  @@index([isCip])
  @@map("fa_assets")
}

// ─── Depreciation Engine ─────────────────────────────────────────────────────────

model FaAssetDepreciation {
  id                  String             @id @default(uuid())
  assetId             String
  asset               FaAsset            @relation(fields: [assetId], references: [id])
  depreciationArea    FaDepreciationArea
  depreciationMethod  FaDepreciationMethod
  usefulLifeYears     Int                @default(0)
  usefulLifeMonths    Int                @default(0)
  usefulLifeUnits     Decimal?           @db.Decimal(19, 4)
  depreciationRate    Decimal?           @db.Decimal(7, 4)
  originalCost        BigInt             @default(0)
  accumulatedDepreciation BigInt         @default(0)
  netBookValue        BigInt             @default(0)
  residualValue       BigInt             @default(0)
  revaluationAmount   BigInt             @default(0)
  impairmentAmount    BigInt             @default(0)
  startDate           DateTime?
  endDate             DateTime?
  isFullyDepreciated  Boolean            @default(false)
  isActive            Boolean            @default(true)
  version             Int                @default(1)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?

  entries             FaDepreciationEntry[]

  @@unique([assetId, depreciationArea])
  @@index([assetId])
  @@index([depreciationArea])
  @@index([isActive])
  @@map("fa_asset_depreciation")
}

model FaDepreciationRun {
  id                  String             @id @default(uuid())
  runNumber           String             @unique @db.VarChar(50)
  depreciationArea    FaDepreciationArea
  periodId            String
  fiscalYearId        String
  runDate             DateTime           @default(now())
  status              FaDepreciationStatus @default(pending)
  totalAssets         Int                @default(0)
  totalDepreciation   BigInt             @default(0)
  processedAssets     Int                @default(0)
  failedAssets        Int                @default(0)
  startedAt           DateTime?
  completedAt         DateTime?
  errorMessage        String?            @db.Text
  createdById         String?            @db.VarChar(36)
  postedToGL          Boolean            @default(false)
  glBatchId           String?            @db.VarChar(36)
  isSimulation        Boolean            @default(false)
  notes               String?            @db.Text
  version             Int                @default(1)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?

  entries             FaDepreciationEntry[]

  @@index([runNumber])
  @@index([periodId])
  @@index([fiscalYearId])
  @@index([status])
  @@index([depreciationArea])
  @@map("fa_depreciation_runs")
}

model FaDepreciationEntry {
  id                  String             @id @default(uuid())
  runId               String?
  run                 FaDepreciationRun? @relation(fields: [runId], references: [id])
  assetId             String
  asset               FaAsset            @relation(fields: [assetId], references: [id])
  deprAreaId          String
  deprArea            FaAssetDepreciation @relation(fields: [deprAreaId], references: [id])
  periodId            String
  fiscalYearId        String
  entryDate           DateTime           @default(now())
  periodNumber        Int                @default(1)
  depreciationAmount  BigInt             @default(0)
  accumulatedDepreciation BigInt         @default(0)
  netBookValueBefore  BigInt             @default(0)
  netBookValueAfter   BigInt             @default(0)
  isCatchUp           Boolean            @default(false)
  isAdjustment        Boolean            @default(false)
  isForecast          Boolean            @default(false)
  isSimulation        Boolean            @default(false)
  isReversal          Boolean            @default(false)
  reversalEntryId     String?            @db.VarChar(36)
  notes               String?            @db.Text
  postedToGL          Boolean            @default(false)
  glBatchId           String?            @db.VarChar(36)
  version             Int                @default(1)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?

  @@index([runId])
  @@index([assetId])
  @@index([deprAreaId])
  @@index([periodId])
  @@index([fiscalYearId])
  @@index([entryDate])
  @@index([postedToGL])
  @@map("fa_depreciation_entries")
}

// ─── Revaluation ──────────────────────────────────────────────────────────────────

model FaRevaluation {
  id                  String             @id @default(uuid())
  assetId             String
  asset               FaAsset            @relation(fields: [assetId], references: [id])
  revaluationNumber   String             @unique @db.VarChar(50)
  revaluationType     FaRevaluationType
  revaluationDate     DateTime
  previousValue       BigInt             @default(0)
  revaluedAmount      BigInt             @default(0)
  newValue            BigInt             @default(0)
  accumulatedDepreciationBefore BigInt   @default(0)
  accumulatedDepreciationAfter  BigInt   @default(0)
  revaluationReserve  BigInt             @default(0)
  reserveAccountId    String?            @db.VarChar(36)
  reference           String?            @db.VarChar(100)
  referenceId         String?            @db.VarChar(36)
  documentNumber      String?            @db.VarChar(50)
  approvedById        String?            @db.VarChar(36)
  approvedAt          DateTime?
  postedToGL          Boolean            @default(false)
  glBatchId           String?            @db.VarChar(36)
  notes               String?            @db.Text
  version             Int                @default(1)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?

  @@index([assetId])
  @@index([revaluationNumber])
  @@index([revaluationDate])
  @@index([revaluationType])
  @@map("fa_revaluations")
}

// ─── Impairment ───────────────────────────────────────────────────────────────────

model FaImpairment {
  id                  String             @id @default(uuid())
  assetId             String
  asset               FaAsset            @relation(fields: [assetId], references: [id])
  impairmentNumber    String             @unique @db.VarChar(50)
  impairmentType      FaImpairmentType
  impairmentDate      DateTime
  carryingAmount      BigInt             @default(0)
  recoverableAmount   BigInt             @default(0)
  impairmentLoss      BigInt             @default(0)
  fairValueLessCost   BigInt?            @default(0)
  valueInUse          BigInt?            @default(0)
  impairmentReversal  BigInt             @default(0)
  isReversal          Boolean            @default(false)
  originalImpairmentId String?           @db.VarChar(36)
  reference           String?            @db.VarChar(100)
  documentNumber      String?            @db.VarChar(50)
  approvedById        String?            @db.VarChar(36)
  approvedAt          DateTime?
  postedToGL          Boolean            @default(false)
  glBatchId           String?            @db.VarChar(36)
  notes               String?            @db.Text
  version             Int                @default(1)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?

  @@index([assetId])
  @@index([impairmentNumber])
  @@index([impairmentDate])
  @@index([impairmentType])
  @@map("fa_impairments")
}

// ─── Disposal ─────────────────────────────────────────────────────────────────────

model FaDisposal {
  id                  String             @id @default(uuid())
  assetId             String
  asset               FaAsset            @relation(fields: [assetId], references: [id])
  disposalNumber      String             @unique @db.VarChar(50)
  disposalType        FaDisposalType
  disposalDate        DateTime
  originalCost        BigInt             @default(0)
  accumulatedDepreciation BigInt         @default(0)
  netBookValue        BigInt             @default(0)
  disposalProceeds    BigInt             @default(0)
  disposalCosts       BigInt             @default(0)
  gainOnDisposal      BigInt             @default(0)
  lossOnDisposal      BigInt             @default(0)
  vatAmount           BigInt             @default(0)
  customerId          String?            @db.VarChar(36)
  customerName        String?            @db.VarChar(255)
  invoiceNumber       String?            @db.VarChar(50)
  invoiceDate         DateTime?
  reason              String?            @db.Text
  reference           String?            @db.VarChar(100)
  documentNumber      String?            @db.VarChar(50)
  approvedById        String?            @db.VarChar(36)
  approvedAt          DateTime?
  postedToGL          Boolean            @default(false)
  glBatchId           String?            @db.VarChar(36)
  notes               String?            @db.Text
  version             Int                @default(1)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?

  @@index([assetId])
  @@index([disposalNumber])
  @@index([disposalType])
  @@index([disposalDate])
  @@map("fa_disposals")
}

// ─── Transfer ─────────────────────────────────────────────────────────────────────

model FaTransfer {
  id                  String             @id @default(uuid())
  assetId             String
  asset               FaAsset            @relation(fields: [assetId], references: [id])
  transferNumber      String             @unique @db.VarChar(50)
  transferDate        DateTime
  fromBranchId        String?            @db.VarChar(36)
  toBranchId          String?            @db.VarChar(36)
  fromCompanyId       String?            @db.VarChar(36)
  toCompanyId         String?            @db.VarChar(36)
  fromCostCenterId    String?            @db.VarChar(36)
  toCostCenterId      String?            @db.VarChar(36)
  fromDepartmentId    String?            @db.VarChar(36)
  toDepartmentId      String?            @db.VarChar(36)
  fromLocationId      String?            @db.VarChar(36)
  toLocationId        String?            @db.VarChar(36)
  fromCustodianId     String?            @db.VarChar(36)
  toCustodianId       String?            @db.VarChar(36)
  fromCustodianName   String?            @db.VarChar(255)
  toCustodianName     String?            @db.VarChar(255)
  transferType        String?            @db.VarChar(20)
  reason              String?            @db.Text
  reference           String?            @db.VarChar(100)
  documentNumber      String?            @db.VarChar(50)
  approvedById        String?            @db.VarChar(36)
  approvedAt          DateTime?
  postedToGL          Boolean            @default(false)
  glBatchId           String?            @db.VarChar(36)
  version             Int                @default(1)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?

  @@index([assetId])
  @@index([transferNumber])
  @@index([transferDate])
  @@index([fromBranchId])
  @@index([toBranchId])
  @@map("fa_transfers")
}

// ─── Split / Merge ────────────────────────────────────────────────────────────────

model FaSplitMerge {
  id                  String             @id @default(uuid())
  operationType       String             @db.VarChar(10)
  documentNumber      String             @db.VarChar(50)
  operationDate       DateTime
  sourceAssetId       String?
  sourceAsset         FaAsset?           @relation(fields: [sourceAssetId], references: [id])
  sourceOriginalCost  BigInt             @default(0)
  sourceAccumulatedDepreciation BigInt   @default(0)
  sourceNetBookValue  BigInt             @default(0)
  targetAssetIds      String?            @db.Text
  targetAssetCodes    String?            @db.Text
  ratios              String?            @db.Text
  reason              String?            @db.Text
  reference           String?            @db.VarChar(100)
  approvedById        String?            @db.VarChar(36)
  approvedAt          DateTime?
  postedToGL          Boolean            @default(false)
  glBatchId           String?            @db.VarChar(36)
  version             Int                @default(1)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?

  @@unique([operationType, documentNumber])
  @@index([sourceAssetId])
  @@index([operationDate])
  @@map("fa_split_merges")
}

// ─── CIP (Construction In Progress) ───────────────────────────────────────────────

model FaCipProject {
  id                  String             @id @default(uuid())
  projectCode         String             @unique @db.VarChar(50)
  projectName         String             @db.VarChar(255)
  projectType         String?            @db.VarChar(50)
  status              String?            @db.VarChar(20)
  companyId           String
  branchId            String?            @db.VarChar(36)
  departmentId        String?            @db.VarChar(36)
  projectManagerId    String?            @db.VarChar(36)
  startDate           DateTime
  expectedEndDate     DateTime?
  actualEndDate       DateTime?
  totalBudget         BigInt             @default(0)
  totalCost           BigInt             @default(0)
  capitalizedAmount   BigInt             @default(0)
  remainingBudget     BigInt             @default(0)
  currencyCode        String             @default("VND") @db.VarChar(3)
  description         String?            @db.Text
  contractNumber      String?            @db.VarChar(50)
  contractorId        String?            @db.VarChar(36)
  contractorName      String?            @db.VarChar(255)
  isExternal          Boolean            @default(true)
  approvalStatus      String?            @db.VarChar(20)
  approvedById        String?            @db.VarChar(36)
  approvedAt          DateTime?
  version             Int                @default(1)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?

  costs               FaCipCost[]
  milestones          FaCipMilestone[]
  settlements         FaCipSettlement[]
  assets              FaAsset[]

  @@index([projectCode])
  @@index([companyId])
  @@index([status])
  @@index([startDate])
  @@map("fa_cip_projects")
}

model FaCipCost {
  id                  String             @id @default(uuid())
  projectId           String
  project             FaCipProject       @relation(fields: [projectId], references: [id])
  costDate            DateTime
  costType            String?            @db.VarChar(50)
  description         String?            @db.Text
  amount              BigInt             @default(0)
  currencyCode        String             @default("VND") @db.VarChar(3)
