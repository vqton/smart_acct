  lessorName          String?            @db.VarChar(255)
  startDate           DateTime
  endDate             DateTime
  leaseTermMonths     Int                @default(0)
  paymentAmount       BigInt             @default(0)
  paymentFrequency    FaLeasePaymentFrequency @default(monthly)
  totalLeaseLiability BigInt             @default(0)
  interestRate        Decimal?           @db.Decimal(7, 4)
  incrementalRate     Decimal?           @db.Decimal(7, 4)
  rightOfUseAsset     BigInt             @default(0)
  accumulatedAmortization BigInt         @default(0)
  currencyCode        String             @default("VND") @db.VarChar(3)
  renewalOption       Boolean            @default(false)
  purchaseOption      Boolean            @default(false)
  terminationOption   Boolean            @default(false)
