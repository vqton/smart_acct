// ─── Customer Master ─────────────────────────────────────────────────────────────

model SlsCustomerGroup {
  id        String   @id @default(uuid())
  code      String   @unique @db.VarChar(20)
  name      String   @db.VarChar(255)
  nameEn    String?  @db.VarChar(255)
  priceGroup SlsPriceGroup @default(retail)
  discountGroup SlsDiscountGroup @default(none)
  paymentTermCode String? @db.VarChar(20)
  isActive  Boolean  @default(true)
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  customers SlsCustomer[]

  @@index([code])
  @@map("sls_customer_groups")
}

model SlsCustomer {
  id                String           @id @default(uuid())
  code              String           @unique @db.VarChar(20)
  name              String           @db.VarChar(255)
  nameEn            String?          @db.VarChar(255)
  groupId           String?
  group             SlsCustomerGroup? @relation(fields: [groupId], references: [id])
  customerType      SlsCustomerType  @default(retail)
  category          SlsCustomerCategory @default(standard)
  classification    String?          @db.VarChar(50)
  // Tax
  taxCode           String?          @db.VarChar(20)
  taxAuthority      String?          @db.VarChar(100)
  taxOffice         String?          @db.VarChar(255)
  // Address
  address           String?          @db.VarChar(500)
  ward              String?          @db.VarChar(100)
  district          String?          @db.VarChar(100)
  province          String?          @db.VarChar(100)
  country           String           @default("VN") @db.VarChar(2)
  postalCode        String?          @db.VarChar(20)
  // Contact
  phone             String?          @db.VarChar(50)
  email             String?          @db.VarChar(255)
  website           String?          @db.VarChar(255)
  // Trade
  paymentTermCode   String?          @db.VarChar(20)
  priceGroup        SlsPriceGroup    @default(retail)
  discountGroup     SlsDiscountGroup @default(none)
  currencyCode      String           @default("VND") @db.VarChar(3)
  creditLimit       BigInt           @default(0)
  creditUsed        BigInt           @default(0)
  creditAvailable   BigInt           @default(0)
  creditStatus      String           @default("good") @db.VarChar(20)
  allowNegativeDebt Boolean          @default(false)
  // Status
  status            SlsCustomerStatus @default(active)
  isActive          Boolean          @default(true)
  isBlacklisted     Boolean          @default(false)
  blacklistReason   String?          @db.Text
  // Sales info
  storeId           String?          @db.VarChar(36)
  salespersonId     String?          @db.VarChar(36)
  branchId          String?          @db.VarChar(36)
  // Registration
  registeredAt      DateTime?
  lastPurchaseAt    DateTime?
  totalPurchases    BigInt           @default(0)
  totalReturns      BigInt           @default(0)
  totalOrders       Int              @default(0)
  // Audit
  version           Int              @default(1)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?

  contacts      SlsCustomerContact[]
  addresses     SlsCustomerAddress[]
  taxInfos      SlsCustomerTaxInfo[]
  orders        SlsSalesOrder[]
  quotations    SlsQuotation[]
  invoices      SlsSalesInvoice[]
  returns       SlsSalesReturn[]
  receipts      SlsCustomerReceipt[]
  loyalty       SlsLoyaltyAccount?
  memberships   SlsMembership[]
  wallets       SlsCustomerWallet[]
  creditHistory SlsCustomerCreditHistory[]

  @@index([code])
  @@index([taxCode])
  @@index([status])
  @@index([groupId])
  @@index([phone])
  @@index([email])
  @@index([isBlacklisted])
  @@map("sls_customers")
}

model SlsCustomerContact {
  id        String   @id @default(uuid())
  customerId String
  customer  SlsCustomer @relation(fields: [customerId], references: [id])
  fullName  String   @db.VarChar(255)
  email     String?  @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  position  String?  @db.VarChar(255)
  isPrimary Boolean  @default(false)
  isActive  Boolean  @default(true)
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([customerId])
  @@map("sls_customer_contacts")
}

model SlsCustomerAddress {
  id         String   @id @default(uuid())
  customerId String
  customer   SlsCustomer @relation(fields: [customerId], references: [id])
  addressType String  @default("shipping") @db.VarChar(20)
  address    String   @db.VarChar(500)
  ward       String?  @db.VarChar(100)
  district   String?  @db.VarChar(100)
  province   String?  @db.VarChar(100)
  country    String   @default("VN") @db.VarChar(2)
  postalCode String?  @db.VarChar(20)
  isDefault  Boolean  @default(false)
  isActive   Boolean  @default(true)
  version    Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  @@index([customerId])
  @@index([addressType])
  @@map("sls_customer_addresses")
}

model SlsCustomerTaxInfo {
  id          String   @id @default(uuid())
  customerId  String
  customer    SlsCustomer @relation(fields: [customerId], references: [id])
  taxCode     String   @db.VarChar(20)
  companyName String?  @db.VarChar(255)
  address     String?  @db.VarChar(500)
  isDefault   Boolean  @default(true)
  isActive    Boolean  @default(true)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([customerId])
  @@map("sls_customer_tax_infos")
}

model SlsCustomerCreditHistory {
  id          String   @id @default(uuid())
  customerId  String
  customer    SlsCustomer @relation(fields: [customerId], references: [id])
  changeType  String   @db.VarChar(50)
  oldLimit    BigInt   @default(0)
  newLimit    BigInt   @default(0)
  oldUsed     BigInt   @default(0)
  newUsed     BigInt   @default(0)
  reason      String?  @db.Text
  changedBy   String   @db.VarChar(100)
  changedAt   DateTime @default(now())

  @@index([customerId])
  @@map("sls_customer_credit_history")
}

model SlsCustomerWallet {
  id          String   @id @default(uuid())
  customerId  String
  customer    SlsCustomer @relation(fields: [customerId], references: [id])
  walletType  String   @default("store_credit") @db.VarChar(20)
  balance     BigInt   @default(0)
  currencyCode String  @default("VND") @db.VarChar(3)
  isActive    Boolean  @default(true)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  transactions SlsWalletTransaction[]

  @@index([customerId])
  @@map("sls_customer_wallets")
}

model SlsWalletTransaction {
  id          String   @id @default(uuid())
  walletId    String
  wallet      SlsCustomerWallet @relation(fields: [walletId], references: [id])
  transactionNumber String @unique @db.VarChar(50)
  direction   String   @db.VarChar(10)
  amount      BigInt   @default(0)
  balanceBefore BigInt @default(0)
  balanceAfter  BigInt @default(0)
  currencyCode String  @default("VND") @db.VarChar(3)
  referenceType String? @db.VarChar(50)
  referenceId  String? @db.VarChar(36)
  description  String? @db.Text
  createdBy    String? @db.VarChar(100)
  createdAt    DateTime @default(now())

  @@index([walletId])
  @@index([referenceType, referenceId])
  @@map("sls_wallet_transactions")
}

// ─── Sales Channel ───────────────────────────────────────────────────────────────

model SlsStore {
  id          String   @id @default(uuid())
  code        String   @unique @db.VarChar(20)
  name        String   @db.VarChar(255)
  nameEn      String?  @db.VarChar(255)
  storeType   String   @default("retail") @db.VarChar(20)
  address     String?  @db.VarChar(500)
  ward        String?  @db.VarChar(100)
  district    String?  @db.VarChar(100)
  province    String?  @db.VarChar(100)
  phone       String?  @db.VarChar(50)
  email       String?  @db.VarChar(255)
  managerId   String?  @db.VarChar(36)
  warehouseId String?  @db.VarChar(36)
  cashBoxId   String?  @db.VarChar(36)
  isActive    Boolean  @default(true)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  salespersons SlsSalesperson[]
  orders       SlsSalesOrder[]

  @@index([code])
  @@index([storeType])
  @@map("sls_stores")
}

model SlsSalesperson {
  id          String   @id @default(uuid())
  storeId     String?
  store       SlsStore? @relation(fields: [storeId], references: [id])
  employeeId  String   @db.VarChar(36)
  code        String   @unique @db.VarChar(20)
  name        String   @db.VarChar(255)
  commissionRate Decimal? @db.Decimal(5, 2)
  targetAmount   BigInt? @default(0)
  achievedAmount BigInt? @default(0)
  isActive    Boolean  @default(true)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  orders SlsSalesOrder[]

  @@index([storeId])
  @@index([employeeId])
  @@index([code])
  @@map("sls_salespersons")
}

// ─── Pricing ─────────────────────────────────────────────────────────────────────

model SlsPriceList {
  id           String   @id @default(uuid())
  code         String   @unique @db.VarChar(20)
  name         String   @db.VarChar(255)
  currencyCode String   @default("VND") @db.VarChar(3)
  isActive     Boolean  @default(true)
  isDefault    Boolean  @default(false)
  priority     Int      @default(0)
  effectiveFrom DateTime?
  effectiveTo  DateTime?
  description  String?  @db.Text
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  items SlsPriceListItem[]

  @@index([code])
  @@index([isDefault])
  @@map("sls_price_lists")
}

model SlsPriceListItem {
  id          String   @id @default(uuid())
  priceListId String
  priceList   SlsPriceList @relation(fields: [priceListId], references: [id])
  itemId      String   @db.VarChar(36)
  itemCode    String   @db.VarChar(50)
  unitPrice   BigInt   @default(0)
  minQuantity Decimal? @db.Decimal(18, 4)
  maxQuantity Decimal? @db.Decimal(18, 4)
  currencyCode String  @default("VND") @db.VarChar(3)
  effectiveFrom DateTime?
  effectiveTo  DateTime?
  isActive    Boolean  @default(true)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([priceListId])
  @@index([itemId])
  @@index([itemCode])
  @@map("sls_price_list_items")
}

// ─── Promotion ───────────────────────────────────────────────────────────────────

model SlsPromotion {
  id              String           @id @default(uuid())
  code            String           @unique @db.VarChar(20)
  name            String           @db.VarChar(255)
  promotionType   SlsPromotionType
  status          SlsPromotionStatus @default(draft)
  description     String?          @db.Text
  // Scope
  appliesTo       String           @default("all") @db.VarChar(20)
  customerGroupIds String?         @db.Text
  storeIds        String?          @db.Text
  itemIds         String?          @db.Text
  // Schedule
  startDate       DateTime
  endDate         DateTime
  // Value
  discountType    SlsDiscountType  @default(percentage)
  discountValue   Decimal          @default(0) @db.Decimal(19, 6)
  discountPercent Decimal          @default(0) @db.Decimal(5, 2)
  maxDiscount     BigInt?
  minOrderAmount  BigInt?
  maxQuantity     Int?
  // Budget
  budgetAmount    BigInt?
  usedAmount      BigInt           @default(0)
  usageLimit      Int?
  usageCount      Int              @default(0)
  perCustomerLimit Int?
  // Approval
  requiresApproval Boolean        @default(false)
  approvedBy      String?         @db.VarChar(100)
  approvedAt      DateTime?
  // Terms
  termsAndConditions String?       @db.Text
  // Metadata
  version         Int              @default(1)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  coupons     SlsCoupon[]
  orderLines  SlsOrderLinePromotion[]

  @@index([code])
  @@index([promotionType])
  @@index([status])
  @@index([startDate, endDate])
  @@map("sls_promotions")
}

model SlsCoupon {
  id            String          @id @default(uuid())
  code          String          @unique @db.VarChar(50)
  promotionId   String
  promotion     SlsPromotion    @relation(fields: [promotionId], references: [id])
  customerId    String?         @db.VarChar(36)
  status        SlsCouponStatus @default(active)
  discountType  SlsDiscountType @default(percentage)
  discountValue Decimal         @default(0) @db.Decimal(19, 6)
  discountPercent Decimal       @default(0) @db.Decimal(5, 2)
  maxDiscount   BigInt?
  minOrderAmount BigInt?
  validFrom     DateTime
  validTo       DateTime
  usageLimit    Int?
  usageCount    Int             @default(0)
  usedAt        DateTime?
  usedBy        String?         @db.VarChar(100)
  version       Int             @default(1)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  @@index([code])
  @@index([promotionId])
  @@index([customerId])
  @@index([status])
  @@map("sls_coupons")
}

// ─── Gift Card ───────────────────────────────────────────────────────────────────

model SlsGiftCard {
  id            String           @id @default(uuid())
  cardNumber    String           @unique @db.VarChar(50)
  pinCode       String?          @db.VarChar(10)
  initialBalance BigInt          @default(0)
  currentBalance BigInt          @default(0)
  currencyCode  String           @default("VND") @db.VarChar(3)
  status        SlsGiftCardStatus @default(active)
  customerId    String?          @db.VarChar(36)
  issuedBy      String           @db.VarChar(100)
  issuedAt      DateTime
  activatedAt   DateTime?
  expiredAt     DateTime?
  lastUsedAt    DateTime?
  version       Int              @default(1)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?

  transactions SlsGiftCardTransaction[]

  @@index([cardNumber])
  @@index([customerId])
  @@index([status])
  @@map("sls_gift_cards")
}

model SlsGiftCardTransaction {
  id                String   @id @default(uuid())
  giftCardId        String
  giftCard          SlsGiftCard @relation(fields: [giftCardId], references: [id])
  transactionNumber String   @unique @db.VarChar(50)
  direction         String   @db.VarChar(10)
  amount            BigInt   @default(0)
  balanceBefore     BigInt   @default(0)
  balanceAfter      BigInt   @default(0)
  currencyCode      String   @default("VND") @db.VarChar(3)
  referenceType     String?  @db.VarChar(50)
  referenceId       String?  @db.VarChar(36)
  description       String?  @db.Text
  createdBy         String?  @db.VarChar(100)
  createdAt         DateTime @default(now())

  @@index([giftCardId])
  @@index([referenceType, referenceId])
  @@map("sls_gift_card_transactions")
}

// ─── Loyalty ─────────────────────────────────────────────────────────────────────

model SlsLoyaltyAccount {
  id              String          @id @default(uuid())
  customerId      String          @unique
  customer        SlsCustomer     @relation(fields: [customerId], references: [id])
  tier            SlsLoyaltyTier  @default(bronze)
  totalPoints     BigInt          @default(0)
  currentPoints   BigInt          @default(0)
  lifetimePoints  BigInt          @default(0)
  lifetimeRevenue BigInt          @default(0)
  currencyCode    String          @default("VND") @db.VarChar(3)
  status          SlsLoyaltyStatus @default(active)
  enrolledAt      DateTime        @default(now())
  tierUpgradedAt  DateTime?
  lastActivityAt  DateTime?
  version         Int             @default(1)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  transactions SlsLoyaltyTransaction[]
  tiers        SlsLoyaltyTierHistory[]

  @@index([customerId])
  @@index([tier])
  @@index([status])
  @@map("sls_loyalty_accounts")
}

model SlsLoyaltyTransaction {
  id                String   @id @default(uuid())
  accountId         String
  account           SlsLoyaltyAccount @relation(fields: [accountId], references: [id])
  transactionNumber String   @unique @db.VarChar(50)
  direction         String   @db.VarChar(10)
  points            BigInt   @default(0)
  balanceBefore     BigInt   @default(0)
  balanceAfter      BigInt   @default(0)
  referenceType     String?  @db.VarChar(50)
  referenceId       String?  @db.VarChar(36)
  description       String?  @db.Text
  createdBy         String?  @db.VarChar(100)
  createdAt         DateTime @default(now())

  @@index([accountId])
  @@index([referenceType, referenceId])
  @@map("sls_loyalty_transactions")
}

model SlsLoyaltyTierHistory {
  id          String          @id @default(uuid())
  accountId   String
  account     SlsLoyaltyAccount @relation(fields: [accountId], references: [id])
  oldTier     SlsLoyaltyTier
  newTier     SlsLoyaltyTier
  changedBy   String          @db.VarChar(100)
  changedAt   DateTime        @default(now())
  reason      String?         @db.Text

  @@index([accountId])
  @@map("sls_loyalty_tier_history")
}

model SlsMembership {
  id              String             @id @default(uuid())
  customerId      String
  customer        SlsCustomer        @relation(fields: [customerId], references: [id])
  membershipNumber String            @unique @db.VarChar(50)
  membershipType  String             @default("standard") @db.VarChar(20)
  status          SlsMembershipStatus @default(pending)
  startDate       DateTime
  endDate         DateTime?
  renewCount      Int                @default(0)
  lastRenewedAt   DateTime?
  cancelledAt     DateTime?
  cancelReason    String?            @db.Text
  version         Int                @default(1)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?

  @@index([customerId])
  @@index([membershipNumber])
  @@index([status])
  @@map("sls_memberships")
}

// ─── Quotation ───────────────────────────────────────────────────────────────────

model SlsQuotation {
  id              String              @id @default(uuid())
  quotationNumber String              @unique @db.VarChar(50)
  companyId       String              @db.VarChar(36)
  branchId        String?             @db.VarChar(36)
  customerId      String
  customer        SlsCustomer         @relation(fields: [customerId], references: [id])
  customerName    String              @db.VarChar(255)
  customerTaxCode String?             @db.VarChar(20)
  storeId         String?             @db.VarChar(36)
  salespersonId   String?             @db.VarChar(36)
  orderSource     SlsOrderSource      @default(manual)
  status          SlsQuotationStatus  @default(draft)
  revisionNumber  Int                 @default(0)
  // Pricing
  currencyCode    String              @default("VND") @db.VarChar(3)
  exchangeRate    Decimal             @default(1) @db.Decimal(18, 6)
  subtotal        BigInt              @default(0)
  discountAmount  BigInt              @default(0)
  taxAmount       BigInt              @default(0)
  grandTotal      BigInt              @default(0)
  // Dates
  quotationDate   DateTime
  validUntil      DateTime?
  expectedDeliveryDate DateTime?
  // Approval
  approvedBy      String?             @db.VarChar(100)
  approvedAt      DateTime?
  rejectedBy      String?             @db.VarChar(100)
  rejectedAt      DateTime?
  rejectReason    String?             @db.Text
  // Conversion
  convertedToOrderId String?          @db.VarChar(36)
  convertedAt     DateTime?
  // Notes
