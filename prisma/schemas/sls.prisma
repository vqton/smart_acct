// ═══════════════════════════════════════════════════════════════════════════════
// SALES MODULE (Order-to-Cash)
// ═══════════════════════════════════════════════════════════════════════════════

enum SlsCustomerStatus {
  active
  inactive
  blocked
  suspended
  pending
}

enum SlsCustomerType {
  individual
  company
  government
  foreign
  vip
  wholesale
  retail
  internal
}

enum SlsCustomerCategory {
  standard
  silver
  gold
  platinum
  diamond
  corporate
  sme
  franchise
}

enum SlsPriceGroup {
  group_a
  group_b
  group_c
  group_d
  retail
  wholesale
  special
}

enum SlsDiscountGroup {
  none
  standard
  preferred
  vip
  staff
  promotional
}

enum SlsOrderStatus {
  draft
  pending_approval
  approved
  confirmed
  processing
  partly_delivered
  fully_delivered
  partly_invoiced
  fully_invoiced
  partly_paid
  fully_paid
  completed
  cancelled
  on_hold
  returned
}

enum SlsOrderType {
