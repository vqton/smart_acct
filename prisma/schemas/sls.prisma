  discount_amount
  buy_x_get_y
  bundle
  combo
  mix_match
  flash_sale
  loyalty
  birthday
  seasonal
  clearance
  free_shipping
  gift_with_purchase
  coupon
  voucher
  tiered
  volume
  campaign
}

enum SlsPromotionStatus {
  draft
  scheduled
  active
  paused
  expired
  cancelled
  completed
}

enum SlsCouponStatus {
  active
  used
  expired
  cancelled
  suspended
}

enum SlsGiftCardStatus {
  active
  partially_used
  fully_used
  expired
  lost
  stolen
  cancelled
