  dunningLevel      Int      @default(0)
  lastDunningDate   DateTime?
  dunningCount      Int      @default(0)
  // Collection
  assignedCollector String?  @db.VarChar(100)
  promiseDate       DateTime?
  promiseAmount     BigInt   @default(0)
  // Write-off
  writtenOffAt      DateTime?
  writeOffReason    String?  @db.Text
  approvedBy        String?  @db.VarChar(100)
  // Bad Debt
  isBadDebt         Boolean  @default(false)
  badDebtAmount     BigInt   @default(0)
  badDebtProvision  BigInt   @default(0)
  // GL
  glBatchId         String?  @db.VarChar(36)
  postedToGL        Boolean  @default(false)
  // Audit
  version           Int      @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  @@index([customerId])
  @@index([invoiceId])
  @@index([status])
  @@index([dueDate])
  @@index([agingBucket])
  @@index([companyId])
  @@index([isOverdue])
  @@map("sls_receivable_accounts")
}

model SlsDunningHistory {
  id              String   @id @default(uuid())
  receivableId    String
  dunningLevel    Int
  dunningDate     DateTime
  dunningMethod   String   @db.VarChar(50)
  dunningTemplate String?  @db.VarChar(255)
  dunningResult   String?  @db.VarChar(20)
  notes           String?  @db.Text
  sentBy          String   @db.VarChar(100)
  responseAt      DateTime?
  responseNotes   String?  @db.Text
  createdAt       DateTime @default(now())

  @@index([receivableId])
  @@index([dunningDate])
  @@map("sls_dunning_history")
}

// ─── Sales Dimension Master Data ─────────────────────────────────────────────────

model SlsBranch {
  id        String   @id @default(uuid())
  code      String   @unique @db.VarChar(20)
  name      String   @db.VarChar(255)
  address   String?  @db.VarChar(500)
  phone     String?  @db.VarChar(50)
  managerId String?  @db.VarChar(36)
  isActive  Boolean  @default(true)
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([code])
  @@map("sls_branches")
}
