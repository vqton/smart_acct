enum SlsOrderSource {
  pos
  retail
  online
  marketplace
  mobile_app
  call_center
  social_commerce
  b2b_portal
  wholesale_portal
  api
  manual
  import
}

enum SlsQuotationStatus {
  draft
  sent
  accepted
  rejected
  expired
  converted
  cancelled
  revised
}

enum SlsDeliveryStatus {
