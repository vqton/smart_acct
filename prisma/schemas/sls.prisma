  closed
}

enum SlsMembershipStatus {
  pending
  active
  suspended
  cancelled
  expired
}

enum SlsReservationStatus {
  pending
  confirmed
  allocated
  picked
  shipped
  cancelled
  expired
  partially_fulfilled
