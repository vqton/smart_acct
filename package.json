{
  "name": "smart_acct",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "fuser -k 8080/tcp 2>/dev/null; true",
    "dev": "npm run build && concurrently -n api,web -c blue,green \"node dist/main.js\" \"wait-on tcp:8080 && npm run dev --prefix frontend\"",
    "start": "node dist/main.js",
    "build": "tsc",
    "build:frontend": "npm run build --prefix frontend",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "check": "tsc --noEmit",
    "prisma:gen": "prisma generate && bash scripts/patch-prisma-imports.sh",
    "codegraph:sync": "codegraph sync",
    "codegraph:status": "codegraph status",
    "seed": "tsx prisma/seed.ts",
    "postinstall": "codegraph init 2>/dev/null; bash scripts/patch-prisma-imports.sh; true"
  },
  "dependencies": {
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/client": "^7.8.0",
    "@types/express": "^5.0.6",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "headroom-ai": "^0.22.4",
    "mariadb": "^3.5.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsx": "^4.22.4",
    "typescript": "~5.8.3",
    "vitest": "^4.1.9"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@colbymchenry/codegraph": "^1.0.1",
    "@nestjs/testing": "^11.1.27",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@types/decimal.js": "^7.4.3",
    "@types/node": "^26.0.0",
    "@types/supertest": "^7.2.0",
    "concurrently": "^10.0.3",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "wait-on": "^9.0.10"
  }
}
